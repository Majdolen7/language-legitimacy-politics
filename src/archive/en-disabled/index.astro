---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../i18n/utils';

const locale = 'en';
---

<BaseLayout
  title="Language, Legitimacy & Politics"
  description="A digital research project on the discursive construction of political legitimacy in the Syrian context after 2011. Ahmad al-Sharʿ as a case study."
  locale={locale}
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">

        <div class="hero__text">
          <p class="hero__overline">DIGITAL DISCOURSE RESEARCH ON SYRIA AFTER 2011</p>

          <h1 class="hero__title">
            Language and the Discursive Construction of Political Legitimacy
            in Contemporary Syria
          </h1>

          <p class="hero__subtitle">Ahmad al-Shar&#x02BF; as a Case Study</p>

          <div class="hero__rule" aria-hidden="true"></div>

          <p class="hero__intro">
            This project examines how political legitimacy is linguistically constructed,
            shifted, and reframed in public speeches, interviews, and political appearances.
            Ahmad al-Shar&#x02BF; serves as a case study for tracing these discursive
            shifts in the Syrian context after 2011.
          </p>

          <div class="hero-phases" role="list" aria-label="Three phases of legitimacy shifts">
            <p class="hero-phases__label">Three phases of legitimacy shifts</p>
            <div class="hero-phases__track">
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2011–2016</span>
                <span class="hero-phases__name">Religious-militant</span>
              </div>
              <div class="hero-phases__connector" aria-hidden="true"></div>
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2017–2024</span>
                <span class="hero-phases__name">Governance / administration</span>
              </div>
              <div class="hero-phases__connector" aria-hidden="true"></div>
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2025–2026</span>
                <span class="hero-phases__name">Institutional / state-oriented</span>
              </div>
            </div>
          </div>

          <div class="hero__actions">
            <a href={withBase('/en/research-question')} class="btn btn--primary">
              Project &amp; Methodology
            </a>
            <a href={withBase('/en/legitimacy-museum')} class="btn btn--outline hero__btn-secondary">
              Legitimacy Museum
            </a>
          </div>
        </div>

        <div class="hero__visual" aria-hidden="true">
          <div class="hero__visual-paper"></div>
          <div class="hero__visual-burgundy"></div>
          <div class="hero__visual-circle-large"></div>
          <div class="hero__visual-circle-small"></div>

          <div class="hero__podium-wrap">
            <svg
              class="hero__podium-svg"
              viewBox="0 0 220 310"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-label="Podium with microphones"
            >
              <ellipse cx="110" cy="304" rx="88" ry="6" fill="#241C18" opacity="0.10"/>
              <path d="M 42 128 L 178 128 L 195 292 L 25 292 Z" fill="#2A1810"/>
              <rect x="36" y="112" width="148" height="22" rx="2" fill="#3A2218"/>
              <rect x="36" y="112" width="148" height="4" rx="2" fill="#4E3025" opacity="0.7"/>
              <line x1="68" y1="196" x2="152" y2="196" stroke="#B28757" stroke-width="1.5" opacity="0.65"/>
              <line x1="78" y1="203" x2="142" y2="203" stroke="#B28757" stroke-width="0.8" opacity="0.4"/>
              <rect x="101" y="174" width="18" height="14" rx="1" fill="none" stroke="#B28757" stroke-width="1" opacity="0.45"/>
              <line x1="88" y1="112" x2="82" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="79" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="79" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <line x1="132" y1="112" x2="138" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="141" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="141" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <rect x="16" y="290" width="188" height="10" rx="2" fill="#1C0E08" opacity="0.85"/>
              <rect x="26" y="286" width="168" height="6" rx="1" fill="#2A1810"/>
            </svg>
          </div>

          <div class="hero__visual-dots"></div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       2. THREE ANALYTICAL DIMENSIONS
       ============================================================ -->
  <section class="section dimensions-section" aria-labelledby="dimensions-title">
    <div class="container">

      <div class="dimensions-header">
        <span class="section-overline">Analytical model</span>
        <h2 class="dimensions-title" id="dimensions-title">
          Three Dimensions of Political Legitimacy
        </h2>
        <p class="dimensions-intro">
          The three dimensions structure the corpus analytically. They build on the three phases
          but do not constitute a complete event history of the Syrian conflict.
        </p>
      </div>

      <div class="dim-grid">

        <article class="dim-card dim-card--1">
          <div class="dim-card__phase">2011–2016</div>
          <h3 class="dim-card__title">Religious-militant legitimacy</h3>
          <p class="dim-card__desc">
            Factional authority, religious-militant framing, jihad networks, and the
            pledge of allegiance (Bay&#x02BF;a) as sources of legitimation.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">Jihad</span>
            <span class="dim-indicator">Bay&#x02BF;a</span>
            <span class="dim-indicator">Umma</span>
            <span class="dim-indicator">Sharia</span>
          </div>
        </article>

        <article class="dim-card dim-card--2">
          <div class="dim-card__phase">2017–2024</div>
          <h3 class="dim-card__title">Administrative / governance legitimacy</h3>
          <p class="dim-card__desc">
            Idlib as a governance centre, administrative performance and security as
            discursive legitimacy sources — HTS as administrative actor.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">Administration</span>
            <span class="dim-indicator">Security</span>
            <span class="dim-indicator">Order</span>
            <span class="dim-indicator">Stability</span>
          </div>
        </article>

        <article class="dim-card dim-card--3">
          <div class="dim-card__phase">2025–2026</div>
          <h3 class="dim-card__title">Institutional / state-oriented legitimacy</h3>
          <p class="dim-card__desc">
            State language, national unity, citizenship and international recognition
            as legitimation frames of the transitional authority.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">State</span>
            <span class="dim-indicator">Citizenship</span>
            <span class="dim-indicator">Recognition</span>
            <span class="dim-indicator">Institutions</span>
          </div>
        </article>

      </div>

      <p class="dimensions-footer-link">
        <a href={withBase('/en/timeline')} class="btn btn--ghost btn--sm">
          Full analytical timeline →
        </a>
      </p>

    </div>
  </section>


  <!-- ============================================================
       3. RESEARCH FOCUS
       ============================================================ -->
  <section class="section research-focus-section" aria-labelledby="research-focus-title">
    <div class="container">

      <div class="research-focus-inner">

        <div class="research-focus-heading">
          <span class="section-overline">Research focus</span>
          <h2 class="research-focus-title" id="research-focus-title">
            Political Legitimacy as Research Object
          </h2>
        </div>

        <div class="research-focus-body">
          <p class="research-focus-text">
            The focus is not the biography of a political actor but the question of how
            political legitimacy is linguistically produced. The project combines discourse
            analysis, source criticism, and digital modelling: the corpus documents materials,
            the timeline structures discursive phases, and the map visualises spatial contexts
            of political legitimacy claims.
          </p>
          <div class="research-focus-pillars">
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">I</span>
              <div>
                <strong class="research-pillar__label">Core object</strong>
                <p class="research-pillar__desc">Political legitimacy — as a linguistically and discursively constructed order</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">II</span>
              <div>
                <strong class="research-pillar__label">Analytical approach</strong>
                <p class="research-pillar__desc">Language analysis and discourse research — how legitimacy is constructed, shifted, and reframed</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">III</span>
              <div>
                <strong class="research-pillar__label">Case study</strong>
                <p class="research-pillar__desc">Ahmad al-Shar&#x02BF; — as a case, not a biography</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">IV</span>
              <div>
                <strong class="research-pillar__label">Digital tools</strong>
                <p class="research-pillar__desc">Corpus, timeline, and map as instruments of the Digital Humanities</p>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>


  <!-- ============================================================
       4. DIGITAL TOOLS
       ============================================================ -->
  <section class="section tools-section" aria-labelledby="tools-title">
    <div class="container">

      <span class="section-overline">Research instruments</span>
      <h2 class="section-title tools-section__title" id="tools-title">Digital Tools of the Project</h2>

      <div class="tools-grid">

        <a href={withBase('/en/legitimacy-museum')} class="tool-card">
          <span class="tool-card__eyebrow">Digital archive</span>
          <h3 class="tool-card__title">Legitimacy Museum</h3>
          <p class="tool-card__desc">
            Curated directory of primary sources with verification status,
            citations, and public research notes.
          </p>
          <span class="tool-card__link" aria-hidden="true">→</span>
        </a>

        <a href={withBase('/en/map')} class="tool-card">
          <span class="tool-card__eyebrow">Interactive map</span>
          <h3 class="tool-card__title">Map of Political Legitimacy</h3>
          <p class="tool-card__desc">
            Spatial contexts of political legitimacy shifts — from the Syrian
            revolution to the transitional authority.
          </p>
          <span class="tool-card__link" aria-hidden="true">→</span>
        </a>

        <a href={withBase('/en/timeline')} class="tool-card">
          <span class="tool-card__eyebrow">Analytical timeline</span>
          <h3 class="tool-card__title">Timeline &amp; Methodology</h3>
          <p class="tool-card__desc">
            Three analytical phases, discursive shifts, actor naming,
            and legitimation strategies at a glance.
          </p>
          <span class="tool-card__link" aria-hidden="true">→</span>
        </a>

      </div>

    </div>
  </section>


  <!-- ============================================================
       5. CASE STUDY
       ============================================================ -->
  <section class="section case-study-section" aria-labelledby="case-study-title">
    <div class="container">
      <div class="case-study-inner">

        <div class="case-study-heading">
          <span class="section-overline">Case study</span>
          <h2 class="section-title case-study-title" id="case-study-title">
            Ahmad al-Shar&#x02BF; as a Case Study
          </h2>
        </div>

        <div class="case-study-body">
          <p class="case-study-text">
            Ahmad al-Shar&#x02BF; is not the overall object of this project. He is the
            case through which discursive shifts in political legitimacy are traced. The
            focus is not the biography but the question: How are legitimacy claims
            linguistically constructed, medially staged, and spatially contextualised?
          </p>
          <a href={withBase('/en/actor-transformation')} class="btn btn--outline">
            Actor naming as a legitimacy indicator →
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<style>

  /* ------------------------------------------------------------------
     HERO
     ------------------------------------------------------------------ */
  .hero {
    background-color: #FFFFFF;
    padding-block: var(--space-3xl) var(--space-2xl);
    border-bottom: 1px solid var(--clr-border-light);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero__text {
    max-width: 640px;
  }

  .hero__overline {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clr-red);
    margin-bottom: var(--space-lg);
    display: block;
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.1rem);
    font-weight: 400;
    color: var(--clr-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    max-width: 20ch;
  }

  .hero__subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.2vw, 1.45rem);
    font-weight: 400;
    font-style: italic;
    color: var(--clr-text-mid);
    line-height: 1.3;
    margin-bottom: var(--space-lg);
  }

  .hero__rule {
    width: 3rem;
    height: 2px;
    background-color: var(--clr-gold);
    margin-bottom: var(--space-lg);
    border-radius: 1px;
  }

  .hero__intro {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--clr-text-mid);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
  }

  .hero__btn-secondary {
    font-size: 0.78rem;
    padding: var(--space-sm) var(--space-md);
  }

  /* Visual */
  .hero__visual {
    position: relative;
    height: 420px;
    flex-shrink: 0;
  }

  .hero__visual-paper {
    position: absolute;
    inset: 0;
    background-color: #EBE4DC;
    border-radius: 2px;
    opacity: 0.55;
  }

  .hero__visual-burgundy {
    position: absolute;
    top: 0;
    right: 0;
    width: 48%;
    height: 44%;
    background-color: #8B2635;
    opacity: 0.60;
  }

  .hero__visual-circle-large {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-42%, -52%);
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background-color: #E0D8D0;
    opacity: 0.45;
  }

  .hero__visual-circle-small {
    position: absolute;
    top: 38%;
    right: 8%;
    transform: translateY(-40%);
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background-color: #D4C9C0;
    opacity: 0.35;
  }

  .hero__podium-wrap {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 190px;
    z-index: 2;
  }

  .hero__podium-svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 3px 10px rgba(36,28,24,0.14));
  }

  .hero__visual-dots {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    width: 80px;
    height: 80px;
    background-image: radial-gradient(#B28757 1.2px, transparent 1.2px);
    background-size: 11px 11px;
    opacity: 0.45;
    z-index: 1;
  }

  /* ------------------------------------------------------------------
     THREE ANALYTICAL DIMENSIONS
     ------------------------------------------------------------------ */
  .dimensions-section {
    background-color: #FFFFFF;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .dimensions-header {
    max-width: 700px;
    margin-bottom: var(--space-2xl);
  }

  .dimensions-title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.2;
    margin: var(--space-xs) 0 var(--space-md);
    letter-spacing: -0.015em;
  }

  .dimensions-intro {
    font-size: 0.875rem;
    color: var(--clr-text-muted);
    line-height: 1.65;
    font-style: italic;
    margin: 0;
  }

  .dim-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .dim-card {
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--transition-mid);
  }

  .dim-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .dim-card--1 { border-top: 4px solid #8B2635; }
  .dim-card--2 { border-top: 4px solid #4A2E22; }
  .dim-card--3 { border-top: 4px solid #2A3848; }

  .dim-card__phase {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--clr-text-muted);
    text-transform: uppercase;
  }

  .dim-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.25;
    margin: 0;
  }

  .dim-card__desc {
    font-size: 0.85rem;
    color: var(--clr-text-mid);
    line-height: 1.65;
    flex: 1;
    margin: 0;
  }

  .dim-card__indicators {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-xs);
  }

  .dim-indicator {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 2px 8px;
    background-color: var(--clr-bg);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    color: var(--clr-text-muted);
    white-space: nowrap;
  }

  .dimensions-footer-link {
    margin-top: var(--space-2xl);
    text-align: center;
    margin-bottom: 0;
  }

  /* ------------------------------------------------------------------
     RESEARCH FOCUS
     ------------------------------------------------------------------ */
  .research-focus-section {
    background-color: #FAF8F5;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .research-focus-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .research-focus-title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 1.85rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.2;
    margin-top: var(--space-xs);
    letter-spacing: -0.015em;
  }

  .research-focus-text {
    font-size: 0.95rem;
    line-height: 1.78;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-xl);
    max-width: 62ch;
  }

  .research-focus-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .research-pillar {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .research-pillar__icon {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--clr-red);
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    width: 1.6rem;
    height: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .research-pillar__label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--clr-text);
    display: block;
    margin-bottom: 3px;
  }

  .research-pillar__desc {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--clr-text-mid);
    line-height: 1.55;
    margin: 0;
  }

  /* ------------------------------------------------------------------
     DIGITAL TOOLS
     ------------------------------------------------------------------ */
  .tools-section {
    background-color: #FFFFFF;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .tools-section__title {
    margin-bottom: var(--space-2xl);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .tool-card {
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition-mid), box-shadow var(--transition-mid);
  }

  .tool-card:hover {
    border-color: var(--clr-red);
    box-shadow: var(--shadow-card-hover);
  }

  .tool-card__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-red);
  }

  .tool-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.25;
    margin: 0;
  }

  .tool-card__desc {
    font-size: 0.875rem;
    color: var(--clr-text-mid);
    line-height: 1.65;
    flex: 1;
    margin: 0;
  }

  .tool-card__link {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--clr-red);
    margin-top: var(--space-xs);
    align-self: flex-start;
    transition: transform var(--transition-fast);
  }

  .tool-card:hover .tool-card__link {
    transform: translateX(3px);
  }

  /* ------------------------------------------------------------------
     CASE STUDY
     ------------------------------------------------------------------ */
  .case-study-section {
    background-color: #FFFFFF;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .case-study-inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .case-study-title {
    border-bottom: none;
    margin-bottom: 0;
  }

  .case-study-text {
    font-size: 1rem;
    line-height: 1.78;
