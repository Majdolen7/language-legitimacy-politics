---
import BaseLayout from '../layouts/BaseLayout.astro';
import timelineData from '../data/timeline.json';
import { withBase } from '../i18n/utils';

const locale = 'de';

const PHASE_COLORS: Record<number, string> = {
  1: '#8B5038',
  2: '#2F4A3C',
  3: '#4A5C38',
  4: '#2A3848',
};
---

<BaseLayout
  title="Akteursbenennung als Indikator diskursiver Legitimitätsverschiebung"
  description="Die systematische Veränderung der Selbstbezeichnung Ahmad al-Sharaas und der Gruppe als sprachlicher Indikator diskursiver Legitimitätsverschiebung — ein Teilaspekt der Legitimationsanalyse."
  locale={locale}
>

<section class="section at-hero">
  <div class="container">
    <span class="page-kicker">Diskursiver Indikator — kein separates Forschungsthema</span>
    <h1 class="page-title">Akteursbenennung als Indikator diskursiver Legitimitätsverschiebung</h1>
    <p class="page-subtitle">
      Die systematische Veränderung der Selbstbezeichnung als sprachlicher Indikator
      der drei Legitimitätsphasen, 2011–2026
    </p>
  </div>
</section>

<!-- Name timeline -->
<section class="section at-names-section">
  <div class="container">
    <span class="section-overline">Selbstbezeichnungen im Wandel</span>
    <h2 class="section-title">Akteurs- und Gruppenbezeichnungen nach Phase</h2>
    <div class="at-framing-note">
      <p>
        Diese Seite ist dem Kern-Forschungskonzept des Projekts untergeordnet:
        <strong>Politische Legitimität als diskursiv konstruierte Kategorie</strong>.
        Die Akteursbenennung ist kein eigenständiges Thema — sie ist ein <em>diskursiver Indikator</em>,
        der zeigt, wie Legitimitätsansprüche über Benennungsstrategien konstruiert und verschoben werden.
      </p>
      <p>
        Jede Umbenennung des Akteurs oder der Gruppe markiert einen Strategiewechsel innerhalb einer
        der drei analytischen Legitimitätsphasen des Projekts (religiös-militärisch / administrativ-Governance / institutionell-staatsorientiert).
      </p>
    </div>
    <p class="at-intro">
      Die systematische Veränderung der Selbstbezeichnung des Akteurs und der Gruppe ist
      ein zentraler sprachlicher Indikator diskursiver Legitimitätsverschiebung. Jede Umbenennung
      markiert einen Strategiewechsel in der Konstruktion politischer Legitimität.
    </p>

    <div class="at-names-grid">
      {timelineData.map((phase) => (
        <div class="at-name-card" style={`border-top-color: ${PHASE_COLORS[phase.phase_number]};`}>
          <div class="at-name-card__phase" style={`color: ${PHASE_COLORS[phase.phase_number]};`}>
            Phase {phase.phase_number} · {phase.year_range}
          </div>
          <h3 class="at-name-card__title">{phase.phase_title_de}</h3>
          <div class="at-name-card__names">
            {phase.actor_naming_de.map((name) => (
              <div class="at-name-item">
                <span class="at-name-item__de">{name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Phase analysis -->
<section class="section section--alt at-phases-section">
  <div class="container">
    <span class="section-overline">Phasenanalyse</span>
    <h2 class="section-title">Legitimationsstrategien und Schlüsselbegriffe</h2>

    {timelineData.map((phase) => (
      <article class="at-phase-block" id={`phase-${phase.phase_number}`}>
        <div class="at-phase-block__header">
          <div class="at-phase-block__num" style={`background-color: ${PHASE_COLORS[phase.phase_number]};`}>
            {phase.phase_number}
          </div>
          <div>
            <span class="at-phase-block__years" style={`color: ${PHASE_COLORS[phase.phase_number]};`}>
              {phase.year_range}
            </span>
            <h3 class="at-phase-block__title">{phase.phase_title_de}</h3>
            <p class="at-phase-block__subtitle">{phase.phase_subtitle_de}</p>
          </div>
        </div>

        <div class="at-phase-block__body">
          <div class="at-phase-block__note">
            <p>{phase.analytical_note_de}</p>
          </div>

          <div class="at-phase-block__meta">
            <div class="at-phase-meta-row">
              <span class="at-phase-meta-key">Dominanter Legitimationstyp</span>
              <span class="at-phase-meta-val">{phase.legitimacy_type_dominant.replace(/_/g, ' ')}</span>
            </div>
            <div class="at-phase-meta-row">
              <span class="at-phase-meta-key">Dominante Strategie</span>
              <span class="at-phase-meta-val">{phase.legitimation_strategy_dominant}</span>
            </div>

            <div class="at-concepts-block">
              <p class="at-concepts-block__label">Schlüsselbegriffe dieser Phase</p>
              <div class="at-concepts-list">
                {phase.dominant_concepts.map(c => (
                  <div class="at-concept-item">
                    <span class="at-concept-item__de">{c.german}</span>
                  </div>
                ))}
              </div>
            </div>

            {phase.key_events && phase.key_events.length > 0 && (
              <div class="at-events-block">
                <p class="at-events-block__label">Schlüsselereignisse</p>
                <ul class="at-events-list">
                  {phase.key_events.map(ev => (
                    <li class="at-event-item">
                      <span class="at-event-item__year" dir="ltr">{ev.year}</span>
                      <span class="at-event-item__desc">{ev.event_de}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<section class="section at-method-note-section">
  <div class="container">
    <div class="at-method-note">
      <p class="at-method-note__text">
        Die Bezeichnungen und Phasengrenzen in dieser Übersicht sind analytische Konstruktionen
        des Projekts und keine offiziellen Kategorien. Die Akteursbenennung wird als
        <em>diskursiver Indikator politischer Legitimitätsverschiebung</em> untersucht —
        nicht als historische Klassifikation. Das Projekt legitimiert oder delegitimiert
        keine politischen Akteure: Es untersucht, wie Legitimitätsansprüche sprachlich
        konstruiert, aufrechterhalten und transformiert werden.
      </p>
    </div>
    <p class="mt-xl">
      <a href={withBase('/methodology')} class="btn btn--outline">Zur Methodologie →</a>
      <a href={withBase('/timeline')} class="btn btn--ghost btn--sm" style="margin-left: 1rem;">Vollständige Timeline →</a>
    </p>
  </div>
</section>

</BaseLayout>

<style>
.at-hero { background: #FFFFFF; border-bottom: 1px solid var(--clr-border); padding-bottom: var(--space-2xl); }
.at-framing-note { border-left: 3px solid var(--clr-red); padding: var(--space-md) var(--space-xl); margin-bottom: var(--space-xl); }
.at-framing-note p { font-family: var(--font-sans); font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.7; margin: 0 0 var(--space-sm); }
.at-framing-note p:last-child { margin-bottom: 0; }
.at-intro { font-family: var(--font-sans); font-size: 0.95rem; color: var(--clr-text-mid); line-height: 1.75; max-width: 65ch; margin-bottom: var(--space-2xl); }
.at-names-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-lg); }
.at-name-card { background: var(--clr-card); border: 1px solid var(--clr-border); border-radius: var(--radius-md); border-top: 4px solid var(--clr-olive); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-md); }
.at-name-card__phase { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.at-name-card__title { font-family: var(--font-serif); font-size: 1rem; font-weight: 400; color: var(--clr-text); line-height: 1.3; }
.at-name-card__title-ar { font-family: var(--font-arabic); font-size: 0.95rem; color: var(--clr-text-muted); line-height: 1.5; margin: 0; }
.at-name-card__names { display: flex; flex-direction: column; gap: var(--space-sm); margin-top: var(--space-xs); }
.at-name-item { display: flex; flex-direction: column; gap: 2px; padding: var(--space-sm) var(--space-md); background: var(--clr-bg-alt); border-radius: var(--radius-sm); border: 1px solid var(--clr-border-light); }
.at-name-item__de { font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text); font-weight: 500; }
.at-name-item__ar { font-family: var(--font-arabic); font-size: 0.88rem; color: var(--clr-text-muted); display: block; text-align: right; }
.at-phases-section { border-top: 1px solid var(--clr-border); }
.at-phase-block { border-top: 1px solid var(--clr-border-light); padding-block: var(--space-2xl); margin-bottom: 0; }
.at-phase-block__header { display: flex; gap: var(--space-xl); align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-xl); border-bottom: 1px solid var(--clr-border-light); }
.at-phase-block__num { display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 50%; color: white; font-family: var(--font-sans); font-size: 1rem; font-weight: 700; flex-shrink: 0; }
.at-phase-block__years { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; display: block; margin-bottom: 4px; }
.at-phase-block__title { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 400; color: var(--clr-text); margin-bottom: var(--space-xs); }
.at-phase-block__subtitle { font-family: var(--font-sans); font-size: 0.85rem; color: var(--clr-text-muted); font-style: italic; margin: 0; }
.at-phase-block__body { display: grid; grid-template-columns: 1fr 20rem; gap: var(--space-2xl); align-items: start; }
.at-phase-block__note p { font-family: var(--font-sans); font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.75; margin: 0; }
.at-phase-meta-row { display: flex; flex-direction: column; gap: 2px; margin-bottom: var(--space-md); }
.at-phase-meta-key { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: var(--clr-text-subtle); }
.at-phase-meta-val { font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text-mid); }
.at-concepts-block { margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--clr-border-light); }
.at-concepts-block__label, .at-events-block__label { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: var(--clr-text-subtle); margin-bottom: var(--space-sm); }
.at-concepts-list { display: flex; flex-direction: column; gap: var(--space-xs); }
.at-concept-item { display: flex; align-items: center; gap: var(--space-sm); padding: 3px var(--space-sm); background: var(--clr-bg-alt); border-radius: var(--radius-sm); }
.at-concept-item__de { font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text-mid); }
.at-events-block { margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--clr-border-light); }
.at-events-list { display: flex; flex-direction: column; gap: var(--space-xs); list-style: none; padding: 0; margin: 0; }
.at-event-item { display: grid; grid-template-columns: 3rem 1fr; gap: var(--space-sm); align-items: baseline; }
.at-event-item__year { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; color: var(--clr-olive); }
.at-event-item__desc { font-family: var(--font-sans); font-size: 0.8rem; color: var(--clr-text-mid); line-height: 1.5; }
.at-method-note { padding: 0; }
.at-method-note__text { font-family: var(--font-sans); font-size: 0.88rem; color: var(--clr-text-muted); line-height: 1.75; border-left: 3px solid var(--clr-olive); padding-left: var(--space-lg); margin: 0; font-style: italic; }
@media (max-width: 1100px) { .at-names-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 760px) { .at-names-grid { grid-template-columns: 1fr; } .at-phase-block__body { grid-template-columns: 1fr; } .at-phase-block__header { flex-direction: column; gap: var(--space-md); } }
</style>
