---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../i18n/utils';
---

<BaseLayout
  title="Language, Legitimacy & Politics"
  description="Ein digitales Forschungsprojekt zu Legitimitätsdiskursen in Syrien nach 2011."
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">

        <!-- Left: text content -->
        <div class="hero__text">
          <p class="hero__overline">DIGITALE DISKURSFORSCHUNG ZU SYRIEN NACH 2011</p>

          <h1 class="hero__title">
            Language and the Discursive Construction of Political Legitimacy
            in Contemporary Syria
          </h1>

          <p class="hero__subtitle">Ahmad al-Shar&#x02BF; as a Case Study</p>

          <div class="hero__rule" aria-hidden="true"></div>

          <p class="hero__intro">
            Das Projekt untersucht, wie politische Legitimität in öffentlichen Reden,
            Interviews und politischen Auftritten sprachlich hergestellt, verschoben
            und neu gerahmt wird. Im Zentrum steht Ahmad al-Shar&#x02BF; als Fallstudie
            für den Wandel politischer Sprache in Syrien nach 2011.
          </p>

          <div class="hero__actions">
            <a href={withBase('/research-question')} class="btn btn--primary">Projekt erkunden</a>
            <a href={withBase('/legitimacy-museum')} class="btn btn--outline hero__btn-secondary">
              Zum Legitimacy Museum
            </a>
          </div>
        </div>

        <!-- Right: visual collage -->
        <div class="hero__visual" aria-hidden="true">
          <div class="hero__visual-paper"></div>
          <div class="hero__visual-burgundy"></div>
          <div class="hero__visual-circle-large"></div>
          <div class="hero__visual-circle-small"></div>

          <!-- Podium SVG — replace src with actual podium image when available -->
          <div class="hero__podium-wrap">
            <svg
              class="hero__podium-svg"
              viewBox="0 0 220 310"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-label="Rednerpult mit Mikrofonen"
            >
              <!-- Shadow -->
              <ellipse cx="110" cy="304" rx="88" ry="6" fill="#241C18" opacity="0.12"/>
              <!-- Podium body -->
              <path d="M 42 128 L 178 128 L 195 292 L 25 292 Z" fill="#2A1810"/>
              <!-- Lectern top face -->
              <rect x="36" y="112" width="148" height="22" rx="2" fill="#3A2218"/>
              <!-- Lectern top edge highlight -->
              <rect x="36" y="112" width="148" height="4" rx="2" fill="#4E3025" opacity="0.7"/>
              <!-- Front panel decorative lines -->
              <line x1="68" y1="196" x2="152" y2="196" stroke="#B28757" stroke-width="1.5" opacity="0.65"/>
              <line x1="78" y1="203" x2="142" y2="203" stroke="#B28757" stroke-width="0.8" opacity="0.4"/>
              <!-- Small LP box on front -->
              <rect x="101" y="174" width="18" height="14" rx="1" fill="none" stroke="#B28757" stroke-width="1" opacity="0.45"/>
              <!-- Left mic stand -->
              <line x1="88" y1="112" x2="82" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <!-- Left mic capsule -->
              <ellipse cx="79" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="79" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <!-- Right mic stand -->
              <line x1="132" y1="112" x2="138" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <!-- Right mic capsule -->
              <ellipse cx="141" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="141" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <!-- Base step -->
              <rect x="16" y="290" width="188" height="10" rx="2" fill="#1C0E08" opacity="0.85"/>
              <rect x="26" y="286" width="168" height="6" rx="1" fill="#2A1810"/>
            </svg>
          </div>

          <!-- Gold dot grid -->
          <div class="hero__visual-dots"></div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       2. THREE ENTRY CARDS
       ============================================================ -->
  <section class="section entry-section">
    <div class="container">

      <div class="entry-grid">

        <article class="entry-card">
          <span class="entry-card__eyebrow">Digitales Archiv</span>
          <h2 class="entry-card__title">Legitimacy Museum</h2>
          <p class="entry-card__sub">Quellen, Korpusmaterialien und Verifikationsstatus</p>
          <p class="entry-card__body">
            Ein pseudodynamisches digitales Archiv für Reden, Interviews, Transkripte,
            Übersetzungen und öffentliche Forschungsnotizen.
          </p>
          <a href={withBase('/legitimacy-museum')} class="entry-card__link">
            Zum Legitimacy Museum <span aria-hidden="true">→</span>
          </a>
        </article>

        <article class="entry-card">
          <span class="entry-card__eyebrow">Interaktive Karte</span>
          <h2 class="entry-card__title">Map</h2>
          <p class="entry-card__sub">Räumliche Dimensionen politischer Sprache</p>
          <p class="entry-card__body">
            Eine interaktive Karte für geografisch verifizierte Diskursereignisse
            und eine klare Trennung nicht geolokalisierter Materialien.
          </p>
          <a href={withBase('/map')} class="entry-card__link">
            Zur Karte <span aria-hidden="true">→</span>
          </a>
        </article>

        <article class="entry-card">
          <span class="entry-card__eyebrow">Methode &amp; Quellen</span>
          <h2 class="entry-card__title">Corpus &amp; Methodologie</h2>
          <p class="entry-card__sub">Korpusbildung, Quellenkritik und Analyse</p>
          <p class="entry-card__body">
            Dokumentation der Materialauswahl, Verifikationslogik, methodischen
            Grenzen und analytischen Kategorien.
          </p>
          <a href={withBase('/methodology')} class="entry-card__link">
            Zur Methodologie <span aria-hidden="true">→</span>
          </a>
        </article>

      </div>

    </div>
  </section>


  <!-- ============================================================
       3. COMPACT HORIZONTAL TIMELINE
       ============================================================ -->
  <section class="section section--alt timeline-preview-section">
    <div class="container">

      <div class="timeline-preview-header">
        <span class="section-overline">Forschungsphasen</span>
        <h2 class="timeline-preview-title">
          Drei Phasen der Transformation politischer Legitimität
        </h2>
      </div>

      <div class="timeline-compact" role="list" aria-label="Forschungsphasen im Überblick">

        <div class="timeline-compact__phase" role="listitem">
          <span class="timeline-compact__year">2011–2016</span>
          <div class="timeline-compact__marker" aria-hidden="true"></div>
          <span class="timeline-compact__label">
            Faktionale und<br/>militärische Phase
          </span>
        </div>

        <div class="timeline-compact__phase" role="listitem">
          <span class="timeline-compact__year">2017–2024</span>
          <div class="timeline-compact__marker" aria-hidden="true"></div>
          <span class="timeline-compact__label">
            Governance-Phase<br/>in Idlib
          </span>
        </div>

        <div class="timeline-compact__phase" role="listitem">
          <span class="timeline-compact__year">2025–2026</span>
          <div class="timeline-compact__marker" aria-hidden="true"></div>
          <span class="timeline-compact__label">
            Institutionalisierungs-<br/>und Übergangsphase
          </span>
        </div>

      </div>

      <p class="timeline-preview-more">
        <a href={withBase('/timeline')} class="btn btn--ghost btn--sm">
          Zur vollständigen Timeline →
        </a>
      </p>

    </div>
  </section>


  <!-- ============================================================
       4. CASE STUDY SECTION
       ============================================================ -->
  <section class="section case-study-section">
    <div class="container">
      <div class="case-study-inner">

        <div class="case-study-heading">
          <span class="section-overline">Forschungsfokus</span>
          <h2 class="section-title case-study-title">
            Ahmad al-Shar&#x02BF; als Fallstudie
          </h2>
        </div>

        <div class="case-study-body">
          <p class="case-study-text">
            Die Fallstudie untersucht nicht die Biografie eines Akteurs, sondern
            die sprachliche und mediale Konstruktion politischer Legitimität über
            verschiedene Phasen hinweg: von bewaffneter Gruppierung und
            Governance-Strukturen bis hin zu Formen institutioneller
            Selbstbeschreibung.
          </p>
          <a href={withBase('/actor-transformation')} class="btn btn--outline">
            Mehr zum Akteurswandel →
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<!-- ================================================================
     PAGE-SPECIFIC STYLES
     ================================================================ -->
<style>

  /* ------------------------------------------------------------------
     HERO LAYOUT
     ------------------------------------------------------------------ */
  .hero {
    background-color: var(--clr-bg);
    padding-block: var(--space-4xl) var(--space-3xl);
    border-bottom: 1px solid var(--clr-border-light);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--space-3xl);
    align-items: center;
  }

  /* ------------------------------------------------------------------
     HERO TEXT
     ------------------------------------------------------------------ */
  .hero__text {
    max-width: 640px;
  }

  .hero__overline {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clr-red);
    margin-bottom: var(--space-lg);
    display: block;
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.1rem);
    font-weight: 400;
    color: var(--clr-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    max-width: 20ch;
  }

  .hero__subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.5vw, 1.55rem);
    font-weight: 400;
    font-style: italic;
    color: var(--clr-text-mid);
    line-height: 1.3;
    margin-bottom: var(--space-lg);
    max-width: none;
  }

  .hero__rule {
    width: 3rem;
    height: 2px;
    background-color: var(--clr-gold);
    margin-bottom: var(--space-lg);
    border-radius: 1px;
  }

  .hero__intro {
    font-size: 0.975rem;
    line-height: 1.75;
    color: var(--clr-text-mid);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
  }

  .hero__btn-secondary {
    font-size: 0.78rem;
    padding: var(--space-sm) var(--space-md);
  }

  /* ------------------------------------------------------------------
     HERO VISUAL — CSS COLLAGE
     ------------------------------------------------------------------ */
  .hero__visual {
    position: relative;
    height: 480px;
    flex-shrink: 0;
  }

  /* Warm paper background */
  .hero__visual-paper {
    position: absolute;
    inset: 0;
    background-color: #F2EAE0;
    border-radius: 2px;
  }

  /* Burgundy block — top-right corner */
  .hero__visual-burgundy {
    position: absolute;
    top: 0;
    right: 0;
    width: 48%;
    height: 44%;
    background-color: #8B2635;
    opacity: 0.88;
  }

  /* Large circle — paper/stamp element */
  .hero__visual-circle-large {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-42%, -52%);
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background-color: #E8DDD4;
    opacity: 0.75;
  }

  /* Smaller overlapping circle */
  .hero__visual-circle-small {
    position: absolute;
    top: 38%;
    right: 8%;
    transform: translateY(-40%);
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background-color: #D9CFC7;
    opacity: 0.55;
  }

  /* Podium container — centered bottom */
  .hero__podium-wrap {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    z-index: 2;
  }

  .hero__podium-svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 4px 12px rgba(36,28,24,0.18));
  }

  /* Gold dot grid — bottom-right corner */
  .hero__visual-dots {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    width: 88px;
    height: 88px;
    background-image: radial-gradient(#B28757 1.2px, transparent 1.2px);
    background-size: 11px 11px;
    opacity: 0.55;
    z-index: 1;
  }

  /* ------------------------------------------------------------------
     THREE ENTRY CARDS
     ------------------------------------------------------------------ */
  .entry-section {
    border-bottom: 1px solid var(--clr-border-light);
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .entry-card {
    background-color: var(--clr-card);
    border: 1px solid var(--clr-border);
    border-top: 3px solid var(--clr-gold);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition-mid), box-shadow var(--transition-mid);
  }

  .entry-card:hover {
    border-top-color: var(--clr-red);
    box-shadow: var(--shadow-card-hover);
  }

  .entry-card__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-red);
    display: block;
  }

  .entry-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.2;
    margin: 0;
  }

  .entry-card__sub {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--clr-text-muted);
    margin: 0;
    max-width: none;
  }

  .entry-card__body {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--clr-text-mid);
    flex: 1;
    margin: 0;
    max-width: none;
  }

  .entry-card__link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--clr-red);
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-top: var(--space-xs);
    transition: color var(--transition-fast);
    align-self: flex-start;
  }

  .entry-card__link:hover {
    color: var(--clr-red-hover);
  }

  /* ------------------------------------------------------------------
     COMPACT HORIZONTAL TIMELINE
     ------------------------------------------------------------------ */
  .timeline-preview-section {
    border-bottom: 1px solid var(--clr-border-light);
  }

  .timeline-preview-header {
    margin-bottom: var(--space-2xl);
  }

  .timeline-preview-title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.2;
    max-width: 52ch;
    margin: 0;
    letter-spacing: -0.015em;
  }

  /* Horizontal timeline track */
  .timeline-compact {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    position: relative;
    padding-block: var(--space-sm);
    list-style: none;
  }

  /* The connecting gold line */
  .timeline-compact::before {
    content: '';
    position: absolute;
    top: calc(var(--space-sm) + 1.4rem + var(--space-sm) + 6px);
    left: calc(100% / 6);
    right: calc(100% / 6);
    height: 1px;
    background-color: var(--clr-gold);
    z-index: 0;
  }

  .timeline-compact__phase {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    position: relative;
    z-index: 1;
    padding-inline: var(--space-sm);
  }

  .timeline-compact__year {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--clr-text-mid);
    text-transform: uppercase;
    white-space: nowrap;
    display: block;
    text-align: center;
  }

  /* Diamond marker — inspired by LP logo underline diamond */
  .timeline-compact__marker {
    width: 12px;
    height: 12px;
    background-color: var(--clr-gold);
    transform: rotate(45deg);
    border: 2px solid var(--clr-bg-alt);
    box-shadow: 0 0 0 1.5px var(--clr-gold);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .timeline-compact__label {
    font-family: var(--font-serif);
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    font-weight: 400;
    color: var(--clr-text);
    text-align: center;
    line-height: 1.35;
    max-width: 18ch;
    display: block;
  }

  .timeline-preview-more {
    margin-top: var(--space-2xl);
    text-align: center;
    margin-bottom: 0;
    max-width: none;
  }

  /* ------------------------------------------------------------------
     CASE STUDY SECTION
     ------------------------------------------------------------------ */
  .case-study-section {
    border-bottom: 1px solid var(--clr-border-light);
  }

  .case-study-inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .case-study-title {
    border-bottom: none;
    margin-bottom: 0;
  }

  .case-study-text {
    font-size: 1rem;
    line-height: 1.78;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-xl);
    max-width: 64ch;
  }

  /* ------------------------------------------------------------------
     RESPONSIVE
     ------------------------------------------------------------------ */
  @media (max-width: 1100px) {
    .hero__inner {
      grid-template-columns: 1fr 360px;
      gap: var(--space-2xl);
    }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      display: none;
    }

    .entry-grid {
      grid-template-columns: 1fr;
    }

    .case-study-inner {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 680px) {
    .hero {
      padding-block: var(--space-2xl) var(--space-xl);
    }

    .hero__title {
      max-width: none;
    }

    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__actions .btn {
      width: 100%;
      justify-content: center;
    }

    .timeline-compact {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .timeline-compact::before {
      display: none;
    }

    .timeline-compact__phase {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-md);
      padding-inline: 0;
    }

    .timeline-compact__year {
      min-width: 5rem;
      text-align: left;
      padding-top: 1px;
    }

    .timeline-compact__marker {
      margin-top: 4px;
      flex-shrink: 0;
    }

    .timeline-compact__label {
      text-align: left;
    }
  }

</style>
