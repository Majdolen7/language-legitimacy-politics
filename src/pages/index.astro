---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../i18n/utils';
---

<BaseLayout
  title="Language, Legitimacy & Politics"
  description="Ein digitales Forschungsprojekt zu politischer Legitimität als sprachlich und diskursiv hergestellter Ordnung in Syrien nach 2011. Ahmad al-Sharʿ als Fallstudie."
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">

        <!-- Left: text content -->
        <div class="hero__text">
          <p class="hero__overline">DIGITALE DISKURSFORSCHUNG ZU SYRIEN NACH 2011</p>

          <h1 class="hero__title">
            Language and the Discursive Construction of Political Legitimacy
            in Contemporary Syria
          </h1>

          <p class="hero__subtitle">Ahmad al-Shar&#x02BF; as a Case Study</p>

          <div class="hero__rule" aria-hidden="true"></div>

          <p class="hero__intro">
            Das Projekt untersucht, wie politische Legitimität in öffentlichen Reden,
            Interviews und politischen Auftritten sprachlich hergestellt, verschoben
            und neu gerahmt wird. Ahmad al-Shar&#x02BF; dient als Fallstudie, um diese
            diskursiven Verschiebungen im syrischen Kontext nach 2011 nachzuzeichnen.
          </p>

          <!-- Mini phase timeline — orientation strip -->
          <div class="hero-phases" role="list" aria-label="Drei Phasen der Legitimitätsverschiebung">
            <p class="hero-phases__label">Drei Phasen der Legitimitätsverschiebung</p>
            <div class="hero-phases__track">
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2011–2016</span>
                <span class="hero-phases__name">Religiös-militärisch</span>
              </div>
              <div class="hero-phases__connector" aria-hidden="true"></div>
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2017–2024</span>
                <span class="hero-phases__name">Governance / Verwaltung</span>
              </div>
              <div class="hero-phases__connector" aria-hidden="true"></div>
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2025–2026</span>
                <span class="hero-phases__name">Institutionell / staatsorientiert</span>
              </div>
            </div>
          </div>

          <div class="hero__actions">
            <a href={withBase('/research-question')} class="btn btn--primary">
              Projekt &amp; Methodologie
            </a>
            <a href={withBase('/legitimacy-museum')} class="btn btn--outline hero__btn-secondary">
              Legitimacy Museum
            </a>
          </div>
        </div>

        <!-- Right: visual -->
        <div class="hero__visual" aria-hidden="true">
          <div class="hero__visual-paper"></div>
          <div class="hero__visual-burgundy"></div>
          <div class="hero__visual-circle-large"></div>
          <div class="hero__visual-circle-small"></div>

          <div class="hero__podium-wrap">
            <svg
              class="hero__podium-svg"
              viewBox="0 0 220 310"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-label="Rednerpult mit Mikrofonen"
            >
              <ellipse cx="110" cy="304" rx="88" ry="6" fill="#241C18" opacity="0.10"/>
              <path d="M 42 128 L 178 128 L 195 292 L 25 292 Z" fill="#2A1810"/>
              <rect x="36" y="112" width="148" height="22" rx="2" fill="#3A2218"/>
              <rect x="36" y="112" width="148" height="4" rx="2" fill="#4E3025" opacity="0.7"/>
              <line x1="68" y1="196" x2="152" y2="196" stroke="#B28757" stroke-width="1.5" opacity="0.65"/>
              <line x1="78" y1="203" x2="142" y2="203" stroke="#B28757" stroke-width="0.8" opacity="0.4"/>
              <rect x="101" y="174" width="18" height="14" rx="1" fill="none" stroke="#B28757" stroke-width="1" opacity="0.45"/>
              <line x1="88" y1="112" x2="82" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="79" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="79" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <line x1="132" y1="112" x2="138" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="141" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="141" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <rect x="16" y="290" width="188" height="10" rx="2" fill="#1C0E08" opacity="0.85"/>
              <rect x="26" y="286" width="168" height="6" rx="1" fill="#2A1810"/>
            </svg>
          </div>

          <div class="hero__visual-dots"></div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       2. THREE ANALYTICAL DIMENSIONS — immediately after hero
       ============================================================ -->
  <section class="section dimensions-section" aria-labelledby="dimensions-title">
    <div class="container">

      <div class="dimensions-header">
        <span class="section-overline">Analytisches Modell</span>
        <h2 class="dimensions-title" id="dimensions-title">
          Drei Dimensionen politischer Legitimität
        </h2>
        <p class="dimensions-intro">
          Die drei Dimensionen strukturieren das Corpus analytisch. Sie bauen auf den
          drei Phasen auf, sind aber keine vollständige Ereignisgeschichte des syrischen Konflikts.
        </p>
      </div>

      <div class="dim-grid">

        <article class="dim-card dim-card--1">
          <div class="dim-card__phase">2011–2016</div>
          <h3 class="dim-card__title">Religiös-militärische Legitimität</h3>
          <p class="dim-card__desc">
            Faktionale Autorität, religiös-militärische Rahmung, Jihad-Netzwerke und Treueschwur
            (Bay&#x02BF;a) als Legitimationsquellen.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">Jihad</span>
            <span class="dim-indicator">Bay&#x02BF;a</span>
            <span class="dim-indicator">Umma</span>
            <span class="dim-indicator">Scharia</span>
          </div>
        </article>

        <article class="dim-card dim-card--2">
          <div class="dim-card__phase">2017–2024</div>
          <h3 class="dim-card__title">Administrative / Governance-Legitimität</h3>
          <p class="dim-card__desc">
            Idlib als Governance-Zentrum, Verwaltungsperformanz und Sicherheit als
            diskursive Legitimitätsquellen — HTS als administrativer Akteur.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">Verwaltung</span>
            <span class="dim-indicator">Sicherheit</span>
            <span class="dim-indicator">Ordnung</span>
            <span class="dim-indicator">Stabilität</span>
          </div>
        </article>

        <article class="dim-card dim-card--3">
          <div class="dim-card__phase">2025–2026</div>
          <h3 class="dim-card__title">Institutionelle / staatsorientierte Legitimität</h3>
          <p class="dim-card__desc">
            Staatliche Sprache, nationale Einheit, Bürgerschaft und internationale
            Anerkennung als Legitimationsrahmen der Übergangsautorität.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">Staat</span>
            <span class="dim-indicator">Bürgerschaft</span>
            <span class="dim-indicator">Anerkennung</span>
            <span class="dim-indicator">Institutionen</span>
          </div>
        </article>

      </div>

      <p class="dimensions-footer-link">
        <a href={withBase('/timeline')} class="btn btn--ghost btn--sm">
          Vollständige analytische Timeline →
        </a>
      </p>

    </div>
  </section>


  <!-- ============================================================
       3. RESEARCH FOCUS
       ============================================================ -->
  <section class="section research-focus-section" aria-labelledby="research-focus-title">
    <div class="container">

      <div class="research-focus-inner">

        <div class="research-focus-heading">
          <span class="section-overline">Forschungsfokus</span>
          <h2 class="research-focus-title" id="research-focus-title">
            Politische Legitimität als Forschungsgegenstand
          </h2>
        </div>

        <div class="research-focus-body">
          <p class="research-focus-text">
            Im Zentrum steht nicht die Biografie eines politischen Akteurs, sondern
            die Frage, wie politische Legitimität sprachlich hergestellt wird. Das Projekt
            verbindet Diskursanalyse, Quellenkritik und digitale Modellierung: Das Corpus
            dokumentiert Materialien, die Timeline strukturiert diskursive Phasen, und die
            Karte visualisiert räumliche Kontexte politischer Legitimitätsansprüche.
          </p>
          <div class="research-focus-pillars">
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">I</span>
              <div>
                <strong class="research-pillar__label">Kernobjekt</strong>
                <p class="research-pillar__desc">Politische Legitimität — als sprachlich und diskursiv hergestellte Ordnung</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">II</span>
              <div>
                <strong class="research-pillar__label">Analytischer Ansatz</strong>
                <p class="research-pillar__desc">Sprachanalyse und Diskursforschung — wie Legitimität konstruiert, verschoben und neu gerahmt wird</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">III</span>
              <div>
                <strong class="research-pillar__label">Fallstudie</strong>
                <p class="research-pillar__desc">Ahmad al-Shar&#x02BF; — als Fall, nicht als Biografie</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">IV</span>
              <div>
                <strong class="research-pillar__label">Digitale Werkzeuge</strong>
                <p class="research-pillar__desc">Corpus, Timeline und Karte als Instrumente der Digital Humanities</p>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>


  <!-- ============================================================
       4. DIGITAL TOOLS
       ============================================================ -->
  <section class="section tools-section" aria-labelledby="tools-title">
    <div class="container">

      <span class="section-overline">Forschungsinstrumente</span>
      <h2 class="section-title tools-section__title" id="tools-title">Digitale Werkzeuge des Projekts</h2>

      <div class="tools-grid">

        <a href={withBase('/legitimacy-museum')} class="tool-card">
          <span class="tool-card__eyebrow">Digitales Archiv</span>
          <h3 class="tool-card__title">Legitimacy Museum</h3>
          <p class="tool-card__desc">
            Kuratiertes Verzeichnis von Primärquellen mit Verifikationsstatus,
            Quellenangaben und öffentlichen Forschungsnotizen.
          </p>
          <span class="tool-card__link" aria-hidden="true">→</span>
        </a>

        <a href={withBase('/map')} class="tool-card">
          <span class="tool-card__eyebrow">Interaktive Karte</span>
          <h3 class="tool-card__title">Kontextkarte politischer Legitimität</h3>
          <p class="tool-card__desc">
            Räumliche Kontexte politischer Legitimitätsverschiebungen — von der
            syrischen Revolution bis zur Übergangsautorität.
          </p>
          <span class="tool-card__link" aria-hidden="true">→</span>
        </a>

        <a href={withBase('/timeline')} class="tool-card">
          <span class="tool-card__eyebrow">Analytische Timeline</span>
          <h3 class="tool-card__title">Timeline &amp; Methodologie</h3>
          <p class="tool-card__desc">
            Drei analytische Phasen, diskursive Verschiebungen, Akteursbenennungen
            und Legitimationsstrategien im Überblick.
          </p>
          <span class="tool-card__link" aria-hidden="true">→</span>
        </a>

      </div>

    </div>
  </section>


  <!-- ============================================================
       5. CASE STUDY NOTE
       ============================================================ -->
  <section class="section case-study-section" aria-labelledby="case-study-title">
    <div class="container">
      <div class="case-study-inner">

        <div class="case-study-heading">
          <span class="section-overline">Fallstudie</span>
          <h2 class="section-title case-study-title" id="case-study-title">
            Ahmad al-Shar&#x02BF; als Fallstudie
          </h2>
        </div>

        <div class="case-study-body">
          <p class="case-study-text">
            Ahmad al-Shar&#x02BF; ist nicht das Gesamtobjekt dieses Projekts. Er ist der
            Fall, durch den diskursive Verschiebungen politischer Legitimität
            nachgezeichnet werden. Im Zentrum steht nicht die Biografie, sondern die
            Frage: Wie werden Legitimitätsansprüche sprachlich konstruiert, medial
            inszeniert und räumlich kontextualisiert?
          </p>
          <a href={withBase('/actor-transformation')} class="btn btn--outline">
            Akteursbenennung als Legitimationsindikator →
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<!-- ================================================================
     PAGE-SPECIFIC STYLES
     ================================================================ -->
<style>

  /* ------------------------------------------------------------------
     HERO
     ------------------------------------------------------------------ */
  .hero {
    background-color: #FFFFFF;
    padding-block: var(--space-3xl) var(--space-2xl);
    border-bottom: 1px solid var(--clr-border-light);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero__text {
    max-width: 640px;
  }

  .hero__overline {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clr-red);
    margin-bottom: var(--space-lg);
    display: block;
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.1rem);
    font-weight: 400;
    color: var(--clr-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    max-width: 20ch;
  }

  .hero__subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.2vw, 1.45rem);
    font-weight: 400;
    font-style: italic;
    color: var(--clr-text-mid);
    line-height: 1.3;
    margin-bottom: var(--space-lg);
  }

  .hero__rule {
    width: 3rem;
    height: 2px;
    background-color: var(--clr-gold);
    margin-bottom: var(--space-lg);
    border-radius: 1px;
  }

  .hero__intro {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--clr-text-mid);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
  }

  .hero__btn-secondary {
    font-size: 0.78rem;
    padding: var(--space-sm) var(--space-md);
  }

  /* Visual — lighter, more elegant */
  .hero__visual {
    position: relative;
    height: 420px;
    flex-shrink: 0;
  }

  .hero__visual-paper {
    position: absolute;
    inset: 0;
    background-color: #EBE4DC;
    border-radius: 2px;
    opacity: 0.55;
  }

  .hero__visual-burgundy {
    position: absolute;
    top: 0;
    right: 0;
    width: 48%;
    height: 44%;
    background-color: #8B2635;
    opacity: 0.60;
  }

  .hero__visual-circle-large {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-42%, -52%);
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background-color: #E0D8D0;
    opacity: 0.45;
  }

  .hero__visual-circle-small {
    position: absolute;
    top: 38%;
    right: 8%;
    transform: translateY(-40%);
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background-color: #D4C9C0;
    opacity: 0.35;
  }

  .hero__podium-wrap {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 190px;
    z-index: 2;
  }

  .hero__podium-svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 3px 10px rgba(36,28,24,0.14));
  }

  .hero__visual-dots {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    width: 80px;
    height: 80px;
    background-image: radial-gradient(#B28757 1.2px, transparent 1.2px);
    background-size: 11px 11px;
    opacity: 0.45;
    z-index: 1;
  }

  /* ------------------------------------------------------------------
     THREE ANALYTICAL DIMENSIONS
     ------------------------------------------------------------------ */
  .dimensions-section {
    background-color: #FFFFFF;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .dimensions-header {
    max-width: 700px;
    margin-bottom: var(--space-2xl);
  }

  .dimensions-title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.2;
    margin: var(--space-xs) 0 var(--space-md);
    letter-spacing: -0.015em;
  }

  .dimensions-intro {
    font-size: 0.875rem;
    color: var(--clr-text-muted);
    line-height: 1.65;
    font-style: italic;
    margin: 0;
  }

  .dim-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .dim-card {
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--transition-mid);
  }

  .dim-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .dim-card--1 { border-top: 4px solid #8B2635; }
  .dim-card--2 { border-top: 4px solid #4A2E22; }
  .dim-card--3 { border-top: 4px solid #2A3848; }

  .dim-card__phase {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--clr-text-muted);
    text-transform: uppercase;
  }

  .dim-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.25;
    margin: 0;
  }

  .dim-card__desc {
    font-size: 0.85rem;
    color: var(--clr-text-mid);
    line-height: 1.65;
    flex: 1;
    margin: 0;
  }

  .dim-card__indicators {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-xs);
  }

  .dim-indicator {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 2px 8px;
    background-color: var(--clr-bg);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    color: var(--clr-text-muted);
    white-space: nowrap;
  }

  .dimensions-footer-link {
    margin-top: var(--space-2xl);
    text-align: center;
    margin-bottom: 0;
  }

  /* ------------------------------------------------------------------
     RESEARCH FOCUS
     ------------------------------------------------------------------ */
  .research-focus-section {
    background-color: #FAF8F5;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .research-focus-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .research-focus-title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 1.85rem);
    font-weight: 400;
    color: var(--clr-text);
    line-height: 1.2;
    margin-top: var(--space-xs);
    letter-spacing: -0.015em;
  }

  .research-focus-text {
    font-size: 0.95rem;
    line-height: 1.78;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-xl);
    max-width: 62ch;
  }

  .research-focus-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .research-pillar {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .research-pillar__icon {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--clr-red);
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    width: 1.6rem;
    height: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .research-pillar__label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--clr-text);
    display: block;
    margin-bottom: 3px;
  }

  .research-pillar__desc {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--clr-text-mid);
    line-height: 1.55;
    margin: 0;
  }

  /* ------------------------------------------------------------------
     DIGITAL TOOLS
     ------------------------------------------------------------------ */
  .tools-section {
    background-color: #FFFFFF;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .tools-section__title {
    margin-bottom: var(--space-2xl);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .tool-card {
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition-mid), box-shadow var(--transition-mid);
  }

  .tool-card:hover {
    border-color: var(--clr-red);
    box-shadow: var(--shadow-card-hover);
  }

  .tool-card__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-red);
  }

  .tool-card__title {
