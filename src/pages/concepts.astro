---
import BaseLayout from '../layouts/BaseLayout.astro';
import conceptsData from '../data/concepts.json';
import { withBase } from '../i18n/utils';

const coreConceptIndex = conceptsData.findIndex(c => c.id === 'concept_01');
const coreConcept = coreConceptIndex >= 0 ? conceptsData[coreConceptIndex] : null;

const indicators = conceptsData.filter(c => c.id !== 'concept_01');

const phase1Indicators = ['concept_07'];
const phase2Indicators = ['concept_04'];
const phase3Indicators = ['concept_02', 'concept_03', 'concept_05', 'concept_06'];

function getIndicatorsByPhase(ids: string[]) {
  return ids.map(id => indicators.find(c => c.id === id)).filter(Boolean);
}
---

<BaseLayout
  title="Begrifflicher Rahmen: Politische Legitimität"
  description="Begrifflicher Rahmen des Projekts: Politische Legitimität als Kernkonzept, diskursiv hergestellt. Sprachliche Indikatoren geordnet nach drei analytischen Dimensionen."
>

  <!-- ============================================================
       PAGE HERO
       ============================================================ -->
  <section class="cg-hero">
    <div class="container">
      <div class="cg-hero__inner">

        <span class="page-kicker">Analytischer Rahmen</span>

        <h1 class="cg-hero__title">Begrifflicher Rahmen: Politische Legitimität</h1>

        <p class="cg-hero__intro">
          Das Projekt untersucht politische Legitimität nicht als feste Eigenschaft eines Akteurs,
          sondern als sprachlich und diskursiv hergestellte Ordnung, die sich über verschiedene Phasen
          hinweg verschiebt. Die Begriffe auf dieser Seite sind keine gleichwertigen Hauptkonzepte —
          sie sind diskursive Indikatoren, Corpus-Signale für unterschiedliche Legitimitätsansprüche.
        </p>

        <div class="cg-hero__method-note">
          <p>
            <strong>Methodischer Hinweis:</strong> Diese Indikatoren sind keine eigenständigen Konzepte.
            Sie sind Corpus-Signale, die dazu dienen, Verschiebungen in Legitimitätsansprüchen zu
            verfolgen. Ihr Vorkommen im Diskurs bedeutet nicht, dass sie als politische Realität
            behandelt werden — analysiert wird ihre diskursive Funktion.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       CORE CONCEPT — POLITISCHE LEGITIMITÄT
       ============================================================ -->
  {coreConcept && (
    <section class="section core-concept-section">
      <div class="container">

        <div class="core-concept-header">
          <span class="section-overline">Kernkonzept</span>
          <h2 class="core-concept-title">Politische Legitimität</h2>
          <p class="core-concept-ar" lang="ar" dir="rtl">
            {coreConcept.arabic} — <span class="core-concept-translit">{coreConcept.transliteration}</span>
          </p>
        </div>

        <div class="core-concept-body">

          <div class="core-concept-main">
            <div class="core-concept-block">
              <p class="label label--section">Analysefrage</p>
              <p class="core-concept-question">{coreConcept.analysis_question_de}</p>
            </div>
            <div class="core-concept-block">
              <p class="label label--section">Analytischer Ansatz</p>
              <p class="core-concept-approach">
                Politische Legitimität wird hier nicht als Eigenschaft behandelt, die ein Akteur
                besitzt oder nicht besitzt. Sie wird als diskursiv hergestellte Ordnung verstanden —
                konstruiert, aufrechterhalten und verschoben durch Sprache, Benennung, Publikumswahl
                und Legitimationsstrategien.
              </p>
            </div>
            <div class="core-concept-block">
              <p class="label label--section">Theoretische Bezugspunkte</p>
              <div class="core-theory-grid">
                <div class="core-theory-item">
                  <span class="core-theory-label">Weber</span>
                  <p class="core-theory-text">{coreConcept.weber_reference}</p>
                </div>
                <div class="core-theory-item">
                  <span class="core-theory-label">van Leeuwen</span>
                  <p class="core-theory-text">{coreConcept.van_leeuwen_reference}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="core-concept-phases">
            <p class="label label--section">Drei Dimensionen</p>
            <div class="core-phase-list">
              <div class="core-phase-item core-phase-item--1">
                <div class="core-phase-item__header">
                  <span class="core-phase-badge">2011–2016</span>
                  <strong>Religiös-militärische Legitimität</strong>
                </div>
                <p>{coreConcept.phase_relevance.phase_1}</p>
              </div>
              <div class="core-phase-item core-phase-item--2">
                <div class="core-phase-item__header">
                  <span class="core-phase-badge">2017–2024</span>
                  <strong>Administrative / Governance-Legitimität</strong>
                </div>
                <p>{coreConcept.phase_relevance.phase_2}</p>
              </div>
              <div class="core-phase-item core-phase-item--3">
                <div class="core-phase-item__header">
                  <span class="core-phase-badge">2025–2026</span>
                  <strong>Institutionelle / staatsorientierte Legitimität</strong>
                </div>
                <p>{coreConcept.phase_relevance.phase_3}</p>
              </div>
            </div>
          </div>

        </div>

      </div>
    </section>
  )}


  <!-- ============================================================
       THREE DIMENSIONS WITH INDICATORS
       ============================================================ -->
  <section class="section section--alt indicators-section">
    <div class="container">

      <div class="indicators-header">
        <span class="section-overline">Sprachliche Indikatoren</span>
        <h2 class="indicators-title">Corpus-Signale nach analytischer Dimension</h2>
        <p class="indicators-intro">
          Die folgenden Begriffe werden im Corpus als sprachliche Indikatoren untersucht.
          Sie sind den drei analytischen Dimensionen zugeordnet — nicht als getrennte
          Hauptkonzepte, sondern als Signale für Verschiebungen in Legitimitätsansprüchen.
        </p>
      </div>

      <!-- Dimension 1 -->
      <div class="dimension-block dimension-block--1">
        <div class="dimension-block__header">
          <span class="dimension-block__years">2011–2016</span>
          <h3 class="dimension-block__title">Religiös-militärische Legitimität</h3>
          <p class="dimension-block__desc">
            Faktionale Autorität, Jihad-Netzwerke, religiöse Autorisierung und
            Treueschwur (Bay&#x02BF;a) als Legitimationsquellen.
          </p>
        </div>
        <div class="indicator-cards">
          {getIndicatorsByPhase(phase1Indicators).map(concept => concept && (
            <div class="indicator-card" id={concept.id}>
              <div class="indicator-card__identity">
                <h4 class="indicator-card__de">{concept.german}</h4>
                <span class="indicator-card__ar" lang="ar" dir="rtl">{concept.arabic}</span>
                <span class="indicator-card__translit">{concept.transliteration}</span>
              </div>
              <p class="indicator-card__question">{concept.analysis_question_de}</p>
              <p class="indicator-card__desc">{concept.description_de}</p>
              <a href={withBase('/corpus')} class="indicator-card__link">Im Corpus suchen →</a>
            </div>
          ))}
          <!-- Phase 1 additional indicators (from corpus, not structured as concepts) -->
          <div class="indicator-inline-list">
            <p class="label label--section">Weitere Indikatoren dieser Phase</p>
            <div class="inline-indicator-tags">
              <span class="inline-tag">Jihad</span>
              <span class="inline-tag">Umma</span>
              <span class="inline-tag">Bay&#x02BF;a</span>
              <span class="inline-tag">Front</span>
              <span class="inline-tag">Bewaffneter Kampf</span>
              <span class="inline-tag">Religiöse Autorisierung</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Dimension 2 -->
      <div class="dimension-block dimension-block--2">
        <div class="dimension-block__header">
          <span class="dimension-block__years">2017–2024</span>
          <h3 class="dimension-block__title">Administrative / Governance-Legitimität</h3>
          <p class="dimension-block__desc">
            Idlib als Governance-Zentrum, Verwaltungsperformanz, Dienstleistungen,
            Sicherheit und Ordnung als diskursive Legitimationsquellen.
          </p>
        </div>
        <div class="indicator-cards">
          {getIndicatorsByPhase(phase2Indicators).map(concept => concept && (
            <div class="indicator-card" id={concept.id}>
              <div class="indicator-card__identity">
                <h4 class="indicator-card__de">{concept.german}</h4>
                <span class="indicator-card__ar" lang="ar" dir="rtl">{concept.arabic}</span>
                <span class="indicator-card__translit">{concept.transliteration}</span>
              </div>
              <p class="indicator-card__question">{concept.analysis_question_de}</p>
              <p class="indicator-card__desc">{concept.description_de}</p>
              <a href={withBase('/corpus')} class="indicator-card__link">Im Corpus suchen →</a>
            </div>
          ))}
          <div class="indicator-inline-list">
            <p class="label label--section">Weitere Indikatoren dieser Phase</p>
            <div class="inline-indicator-tags">
              <span class="inline-tag">Verwaltung</span>
              <span class="inline-tag">Dienstleistungen</span>
              <span class="inline-tag">Ordnung</span>
              <span class="inline-tag">Stabilität</span>
              <span class="inline-tag">Institutionen vor Ort</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Dimension 3 -->
      <div class="dimension-block dimension-block--3">
        <div class="dimension-block__header">
          <span class="dimension-block__years">2025–2026</span>
          <h3 class="dimension-block__title">Institutionelle / staatsorientierte Legitimität</h3>
          <p class="dimension-block__desc">
            Staatliche Sprache, nationale Einheit, Bürgerschaft und internationale
            Anerkennung als Legitimationsrahmen der Übergangsautorität.
          </p>
        </div>
        <div class="indicator-cards indicator-cards--grid">
          {getIndicatorsByPhase(phase3Indicators).map(concept => concept && (
            <div class="indicator-card" id={concept.id}>
              <div class="indicator-card__identity">
                <h4 class="indicator-card__de">{concept.german}</h4>
                <span class="indicator-card__ar" lang="ar" dir="rtl">{concept.arabic}</span>
                <span class="indicator-card__translit">{concept.transliteration}</span>
              </div>
              <p class="indicator-card__question">{concept.analysis_question_de}</p>
              <p class="indicator-card__desc">{concept.description_de}</p>
              <a href={withBase('/corpus')} class="indicator-card__link">Im Corpus suchen →</a>
            </div>
          ))}
          <div class="indicator-inline-list indicator-inline-list--full">
            <p class="label label--section">Weitere Indikatoren dieser Phase</p>
            <div class="inline-indicator-tags">
              <span class="inline-tag">Staat</span>
              <span class="inline-tag">Institutionen</span>
              <span class="inline-tag">Nationale Einheit</span>
              <span class="inline-tag">Übergangsregierung</span>
              <span class="inline-tag">Verfassung</span>
              <span class="inline-tag">Diplomatische Sprache</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ============================================================
       METHODISCHE HINWEISBOX
       ============================================================ -->
  <section class="section cg-note-section">
    <div class="container">
      <div class="cg-note-box">

        <div class="cg-note-box__icon" aria-hidden="true">※</div>

        <div class="cg-note-box__content">
          <h3 class="cg-note-box__title">
            Methodischer Hinweis zur Begriffsverwendung
          </h3>
          <p>
            Diese Begriffe sind keine neutralen Wörter, sondern analytische Kategorien.
            Sie werden im Projekt durch Corpus-Belege überprüft und dürfen nicht ohne
            Quellengrundlage als feste Bedeutungen behandelt werden. Das Vorkommen eines
            Begriffs im Diskurs bedeutet nicht, dass er als politische Realität gilt.
          </p>
          <p>
            Alle Einordnungen sind als vorläufige analytische Rahmungen zu verstehen,
            die im Laufe der Materialauswertung überprüft, angepasst und revidiert werden.
            Fehlende Belege sind als Platzhalter markiert.
          </p>
          <div class="cg-note-box__actions">
            <a href={withBase('/methodology')} class="btn btn--outline btn--sm">
              Zur Methodologie
            </a>
            <a href={withBase('/corpus')} class="btn btn--outline btn--sm">
              Corpus &amp; Quellen
            </a>
            <a href={withBase('/timeline')} class="btn btn--ghost btn--sm">
              Zur analytischen Timeline →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<!-- ================================================================
     PAGE-SPECIFIC STYLES
     ================================================================ -->
<style>

  /* ------------------------------------------------------------------
     HERO
     ------------------------------------------------------------------ */
  .cg-hero {
    background-color: var(--clr-bg-alt);
    padding-block: var(--space-3xl) var(--space-2xl);
    border-bottom: 1px solid var(--clr-border);
  }

  .cg-hero__inner {
    max-width: 800px;
  }

  .cg-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--clr-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
    margin-top: var(--space-xs);
  }

  .cg-hero__intro {
    font-size: 0.975rem;
    line-height: 1.72;
    color: var(--clr-text-mid);
    max-width: 68ch;
    margin-bottom: var(--space-xl);
  }

  .cg-hero__method-note {
    background-color: var(--clr-card);
    border: 1px solid var(--clr-border-light);
    border-left: 3px solid var(--clr-olive);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-md) var(--space-lg);
  }

  .cg-hero__method-note p {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--clr-text-mid);
    line-height: 1.65;
    margin: 0;
    max-width: 68ch;
  }

  /* ------------------------------------------------------------------
     CORE CONCEPT
     ------------------------------------------------------------------ */
  .core-concept-section {
    border-bottom: 1px solid var(--clr-border);
  }

  .core-concept-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--clr-border-light);
  }

  .core-concept-title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 400;
    color: var(--clr-text);
    margin-top: var(--space-xs);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.02em;
  }

  .core-concept-ar {
    font-family: var(--font-arabic);
    font-size: 1.2rem;
    direction: rtl;
    color: var(--clr-text-muted);
    display: block;
    text-align: left;
    margin: 0;
    line-height: 1.5;
  }

  .core-concept-translit {
    font-family: var(--font-sans);
    font-style: italic;
    font-size: 0.85rem;
    direction: ltr;
    display: inline;
    color: var(--clr-text-subtle);
  }

  .core-concept-body {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .core-concept-block {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--clr-border-light);
  }

  .core-concept-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .core-concept-question {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--clr-text);
    line-height: 1.55;
    margin-top: var(--space-sm);
    max-width: 60ch;
  }

  .core-concept-approach {
    font-size: 0.9rem;
    color: var(--clr-text-mid);
    line-height: 1.75;
    margin-top: var(--space-sm);
    max-width: none;
  }

  .core-theory-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .core-theory-item {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: var(--space-sm);
    align-items: start;
  }

  .core-theory-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--clr-olive);
    text-transform: uppercase;
    padding-top: 2px;
  }

  .core-theory-text {
    font-size: 0.82rem;
    color: var(--clr-text-mid);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }

  /* Phase list in core concept */
  .core-phase-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .core-phase-item {
    padding: var(--space-md) var(--space-lg);
    background-color: var(--clr-bg);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
  }

  .core-phase-item--1 { border-left: 3px solid var(--clr-phase-1); }
  .core-phase-item--2 { border-left: 3px solid var(--clr-primary); }
  .core-phase-item--3 { border-left: 3px solid var(--clr-text-mid); }

  .core-phase-item__header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .core-phase-badge {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--clr-text-muted);
    text-transform: uppercase;
    background-color: var(--clr-bg-alt);
    border: 1px solid var(--clr-border);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .core-phase-item strong {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--clr-text);
  }

  .core-phase-item p {
    font-size: 0.82rem;
    color: var(--clr-text-mid);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }

  /* ------------------------------------------------------------------
     INDICATORS SECTION
     ------------------------------------------------------------------ */
  .indicators-section {
    border-bottom: 1px solid var(--clr-border);
  }

  .indicators-header {
    margin-bottom: var(--space-3xl);
    max-width: 700px;
  }

  .indicators-title {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--clr-text);
    margin: var(--space-xs) 0 var(--space-md);
    letter-spacing: -0.015em;
  }

  .indicators-intro {
    font-size: 0.9rem;
    color: var(--clr-text-mid);
    line-height: 1.72;
    margin: 0;
    max-width: none;
  }

  /* Dimension block */
  .dimension-block {
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid var(--clr-border-light);
  }

  .dimension-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .dimension-block__header {
    margin-bottom: var(--space-2xl);
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    border: 1px solid var(--clr-border);
    background-color: var(--clr-bg);
  }

  .dimension-block--1 .dimension-block__header { border-top: 4px solid var(--clr-phase-1); }
  .dimension-block--2 .dimension-block__header { border-top: 4px solid var(--clr-primary); }
  .dimension-block--3 .dimension-block__header { border-top: 4px solid var(--clr-text-mid); }

  .dimension-block__years {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--clr-text-muted);
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .dimension-block__title {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    font-weight: 400;
    color: var(--clr-text);
    margin: 0 0 var(--space-sm);
    line-height: 1.25;
  }

  .dimension-block__desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--clr-text-mid);
    line-height: 1.65;
    margin: 0;
    max-width: 70ch;
  }

  /* Indicator cards */
  .indicator-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .indicator-cards--grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .indicator-card {
    background-color: var(--clr-card);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .indicator-card__identity {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-sm);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--clr-border-light);
  }

  .indicator-card__de {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--clr-text);
    margin: 0;
  }

  .indicator-card__ar {
    font-family: var(--font-arabic);
    font-size: 1rem;
    direction: rtl;
    color: var(--clr-text-muted);
    line-height: 1.4;
  }

  .indicator-card__translit {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--clr-text-subtle);
  }

  .indicator-card__question {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--clr-text);
    line-height: 1.55;
    margin: 0;
    max-width: 60ch;
  }

  .indicator-card__desc {
    font-size: 0.85rem;
    color: var(--clr-text-mid);
    line-height: 1.7;
    flex: 1;
    margin: 0;
    max-width: none;
  }

  .indicator-card__link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--clr-red);
    text-decoration: none;
    margin-top: auto;
    transition: color var(--transition-fast);
    align-self: flex-start;
  }

  .indicator-card__link:hover {
    color: var(--clr-red-hover);
  }

  /* Inline additional indicators list */
  .indicator-inline-list {
    background-color: var(--clr-bg-alt);
    border: 1px dashed var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .indicator-inline-list--full {
