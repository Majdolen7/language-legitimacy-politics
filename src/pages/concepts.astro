---
import BaseLayout from '../layouts/BaseLayout.astro';
import conceptsData from '../data/concepts.json';
import { withBase } from '../i18n/utils';

/* ------------------------------------------------------------------
   Build lookup: concept ID → object (for related-concept links)
   ------------------------------------------------------------------ */
const conceptMap = Object.fromEntries(conceptsData.map(c => [c.id, c]));

/* ------------------------------------------------------------------
   Display helpers
   ------------------------------------------------------------------ */
const legitimacyLabels: Record<string, string> = {
  religious_militant_legitimacy:   'Religiös-militärische Legitimität',
  revolutionary_legitimacy:        'Revolutionäre Legitimität',
  administrative_legitimacy:       'Administrative Legitimität',
  security_performance_legitimacy: 'Sicherheitsperformanz-Legitimität',
  national_legitimacy:             'Nationale Legitimität',
  international_legitimacy:        'Internationale Legitimität',
  procedural_legal_legitimacy:     'Prozedural-rechtliche Legitimität',
};

const legitTagSuffix: Record<string, string> = {
  religious_militant_legitimacy:   'religious',
  revolutionary_legitimacy:        'revolutionary',
  administrative_legitimacy:       'administrative',
  security_performance_legitimacy: 'security',
  national_legitimacy:             'national',
  international_legitimacy:        'international',
  procedural_legal_legitimacy:     'procedural',
};

/* ------------------------------------------------------------------
   Analytically derived: which phase is most central for each concept.
   These are analytical judgments from the project framework,
   not invented facts.
   ------------------------------------------------------------------ */
const strongestPhase: Record<string, string> = {
  concept_01: 'Alle drei Phasen (Hauptkonzept)',
  concept_02: 'Phase 3 — 2025',
  concept_03: 'Phase 3 — 2025',
  concept_04: 'Phase 2 — 2017–2024',
  concept_05: 'Phase 3 — 2025',
  concept_06: 'Phase 3 — 2025',
  concept_07: 'Phase 1 — 2011–2016',
};

function truncate(text: string, max: number): string {
  if (!text || text.length <= max) return text;
  const cut = text.lastIndexOf(' ', max);
  return text.substring(0, cut > 0 ? cut : max) + ' …';
}

/* Helper: first 1–2 legit-type labels for matrix column */
function matrixLegitimation(concept: (typeof conceptsData)[number]): string {
  return concept.legitimacy_types
    .slice(0, 2)
    .map(t => legitimacyLabels[t] || t)
    .join('; ');
}

/* Helper: first 2 related concept names for matrix column */
function matrixNeighbors(concept: (typeof conceptsData)[number]): string {
  return concept.related_concepts
    .slice(0, 2)
    .map(id => {
      const c = conceptMap[id];
      return c ? `${c.arabic} / ${c.german}` : id;
    })
    .join(' · ');
}
---

<BaseLayout
  title="Concept Gallery"
  description="Sieben analytische Kernkonzepte: Legitimität, Staat, ziviler Staat, Sicherheit, Bürgerschaft, internationale Anerkennung und Scharia — als Analyseinstrumente für den syrischen Islamismus nach 2011."
>

  <!-- ============================================================
       PAGE HERO
       ============================================================ -->
  <section class="cg-hero">
    <div class="container">
      <div class="cg-hero__inner">

        <span class="page-kicker">Begriffe als Analyseinstrumente</span>

        <div class="cg-hero__title-block">
          <h1 class="cg-hero__title">Concept Gallery</h1>
          <p class="cg-hero__title-ar" lang="ar" dir="rtl">معرض المفاهيم</p>
        </div>

        <p class="cg-hero__intro">
          Die Concept Gallery sammelt zentrale Begriffe, durch die Legitimität,
          Staatlichkeit und politische Zugehörigkeit im syrischen Islamismus
          nach 2011 diskursiv konstruiert werden. Die Begriffe sind keine
          neutralen Wörter — sie sind analytische Kategorien, deren Bedeutung
          sich je nach Phase, Publikum und politischem Kontext verschiebt.
        </p>

        <!-- Quick-jump anchors -->
        <nav class="cg-hero__anchors" aria-label="Zu einem Konzept springen">
          {conceptsData.map(c => (
            <a href={`#${c.id}`} class="cg-anchor-link">
              <span class="cg-anchor-link__ar" lang="ar" dir="rtl">{c.arabic}</span>
              <span class="cg-anchor-link__de">{c.german}</span>
            </a>
          ))}
        </nav>

      </div>
    </div>
  </section>


  <!-- ============================================================
       METHODISCHE EINLEITUNG
       ============================================================ -->
  <section class="section section--card cg-method-intro">
    <div class="container">
      <div class="cg-method-inner">

        <div>
          <span class="section-overline">Konzeptanalyse als Methode</span>
          <h2 class="cg-method-title">Wie werden Konzepte hier verstanden?</h2>
        </div>

        <div class="cg-method-grid">
          <div class="cg-method-point">
            <span class="cg-method-point__num">I</span>
            <p>
              Konzepte werden nicht als feste Wörter mit stabiler Bedeutung
              verstanden. Entscheidend ist, <em>wie</em> sie verwendet werden:
              in welchem Kontext, mit welchen Nachbarbegriffen, an welches
              Publikum gerichtet.
            </p>
          </div>
          <div class="cg-method-point">
            <span class="cg-method-point__num">II</span>
            <p>
              Analysiert werden semantische Felder, Benennungsstrategien,
              Pronomen (wir, das Volk, die Syrer) und die Verschiebung
              von religiöser zu staatlicher Sprache.
            </p>
          </div>
          <div class="cg-method-point">
            <span class="cg-method-point__num">III</span>
            <p>
              Die Begriffe dienen als Brücke zwischen Corpus, Timeline und
              Forschungsfrage. Jede Karte ist durch Corpus-Einträge
              überprüfbar und durch theoretische Bezugspunkte verankert
              (Weber, van Leeuwen, Diskursanalyse).
            </p>
          </div>
          <div class="cg-method-point">
            <span class="cg-method-point__num">IV</span>
            <p>
              Das Erscheinen eines Begriffs im Diskurs bedeutet nicht, dass
              er als Realität behandelt wird. Analysiert wird die diskursive
              Funktion, nicht die normative Gültigkeit.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       KONZEPTKARTEN GRID
       Concept 01 spans full width (primary concept).
       Concepts 02–07 in 2-column grid.
       ============================================================ -->
  <section class="section cg-cards-section">
    <div class="container">

      <span class="section-overline">Sieben Konzepte · سبعة مفاهيم</span>
      <h2 class="section-title">Die Kernkonzepte im Überblick</h2>

      <div class="gallery-grid">
        {conceptsData.map((concept, idx) => (
          <article
            id={concept.id}
            class={`gallery-card${idx === 0 ? ' gallery-card--primary' : ''}`}
            style={`--card-accent: ${concept.color_accent}`}
          >

            <!-- Card header: number, Arabic, transliteration, German -->
            <header class="gallery-card__header">
              <span class="gallery-card__num" aria-hidden="true">
                {String(concept.sort_order).padStart(2, '0')}
              </span>
              <div class="gallery-card__identity">
                <span class="gallery-card__ar" lang="ar" dir="rtl">
                  {concept.arabic}
                </span>
                <span class="gallery-card__translit">
                  {concept.transliteration}
                </span>
                <h3 class="gallery-card__de">{concept.german}</h3>
              </div>
            </header>

            <!-- Analysefrage -->
            <div class="gallery-card__section">
              <p class="label label--section">Analysefrage</p>
              <p class="gallery-card__question">{concept.analysis_question_de}</p>
            </div>

            <!-- Beschreibung -->
            <div class="gallery-card__section">
              <p class="label label--section">Beschreibung</p>
              <p class="gallery-card__desc">{concept.description_de}</p>
            </div>

            <!-- Phasenrelevanz -->
            <div class="gallery-card__section">
              <p class="label label--section">Phasenrelevanz</p>
              <div class="gallery-phase-table">
                <div class="gallery-phase-row">
                  <span class="phase-badge phase-badge--1 gallery-phase-badge">
                    2011–16
                  </span>
                  <p class="gallery-phase-text">{concept.phase_relevance.phase_1}</p>
                </div>
                <div class="gallery-phase-row">
                  <span class="phase-badge phase-badge--2 gallery-phase-badge">
                    2017–24
                  </span>
                  <p class="gallery-phase-text">{concept.phase_relevance.phase_2}</p>
                </div>
                <div class="gallery-phase-row">
                  <span class="phase-badge phase-badge--3 gallery-phase-badge">
                    2025
                  </span>
                  <p class="gallery-phase-text">{concept.phase_relevance.phase_3}</p>
                </div>
              </div>
            </div>

            <!-- Theoretischer Rahmen (compact) -->
            <div class="gallery-card__section">
              <p class="label label--section">Theoretischer Rahmen</p>
              <div class="gallery-theory-block">
                <div class="gallery-theory-row">
                  <span class="gallery-theory-label">Weber</span>
                  <p class="gallery-theory-text">{concept.weber_reference}</p>
                </div>
                <div class="gallery-theory-row">
                  <span class="gallery-theory-label">van Leeuwen</span>
                  <p class="gallery-theory-text">{concept.van_leeuwen_reference}</p>
                </div>
              </div>
            </div>

            <!-- Footer: legit types + related concepts + corpus link -->
            <footer class="gallery-card__footer">

              <div class="gallery-card__legit-types">
                <span class="label" style="display:block; margin-bottom: var(--space-xs);">
                  Legitimationstypen
                </span>
                <div class="gallery-legit-tags">
                  {concept.legitimacy_types.map(type => (
                    <span class={`legit-tag legit-tag--${legitTagSuffix[type] ?? 'national'}`}>
                      {legitimacyLabels[type] ?? type}
                    </span>
                  ))}
                </div>
              </div>

              {concept.related_concepts.length > 0 && (
                <div class="gallery-card__related">
                  <span class="label">Verwandte Konzepte</span>
                  <div class="gallery-related-links">
                    {concept.related_concepts.map(id => {
                      const rel = conceptMap[id];
                      return rel ? (
                        <a href={`#${id}`} class="gallery-related-tag">
                          <span lang="ar" dir="rtl">{rel.arabic}</span>
                          {' / '}
                          {rel.german}
                        </a>
                      ) : null;
                    })}
                  </div>
                </div>
              )}

              <a href={withBase('/corpus')} class="btn btn--ghost btn--sm gallery-corpus-link">
                Im Corpus suchen →
              </a>

            </footer>

          </article>
        ))}
      </div>

    </div>
  </section>


  <!-- ============================================================
       VERGLEICHENDE MINI-MATRIX
       ============================================================ -->
  <section class="section section--alt cg-matrix-section">
    <div class="container">

      <span class="section-overline">Analytischer Vergleich</span>
      <h2 class="section-title">Vergleichende Mini-Matrix der Konzepte</h2>

      <div class="corpus-table-wrap">
        <table class="corpus-table cg-matrix-table">
          <thead>
            <tr>
              <th scope="col">Konzept</th>
              <th scope="col">Analysefrage (Kurzform)</th>
              <th scope="col">Stärkste Phase</th>
              <th scope="col">Zentrale Nachbarbegriffe</th>
              <th scope="col">Mögliche Legitimationsfunktion</th>
            </tr>
          </thead>
          <tbody>
            {conceptsData.map(concept => (
              <tr>
                <td>
                  <a href={`#${concept.id}`} class="cg-matrix-concept-link">
                    <span class="cg-matrix-ar" lang="ar" dir="rtl">{concept.arabic}</span>
                    <span class="cg-matrix-de">{concept.german}</span>
                  </a>
                </td>
                <td class="cg-matrix-question">
                  {truncate(concept.analysis_question_de, 80)}
                </td>
                <td>
                  <span class="cg-matrix-phase">{strongestPhase[concept.id]}</span>
                </td>
                <td class="cg-matrix-neighbors">
                  {matrixNeighbors(concept)}
                </td>
                <td class="cg-matrix-legit">
                  {matrixLegitimation(concept)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

    </div>
  </section>


  <!-- ============================================================
       METHODISCHE HINWEISBOX
       ============================================================ -->
  <section class="section cg-note-section">
    <div class="container">
      <div class="cg-note-box">

        <div class="cg-note-box__icon" aria-hidden="true">※</div>

        <div class="cg-note-box__content">
          <h3 class="cg-note-box__title">
            Methodischer Hinweis zur Concept Gallery
          </h3>
          <p>
            Diese Begriffe sind keine neutralen Wörter, sondern analytische
            Kategorien. Sie werden im Projekt durch Corpus-Belege überprüft
            und dürfen nicht ohne Quellengrundlage als feste Bedeutungen
            behandelt werden. Das Vorkommen eines Begriffs im Diskurs
            bedeutet nicht, dass er als politische Realität gilt.
          </p>
          <p>
            Fehlende Belege sind als Platzhalter markiert
            (<em>ZITAT NACH TRANSKRIPTION EINFÜGEN / QUELLE EINFÜGEN</em>).
            Analytische Einordnungen ohne Corpus-Grundlage sind ausdrücklich
            als vorläufig gekennzeichnet.
          </p>
          <div class="cg-note-box__actions">
            <a href={withBase('/methodology')} class="btn btn--outline btn--sm">
              Zur Methodologie
            </a>
            <a href={withBase('/corpus')} class="btn btn--outline btn--sm">
              Corpus &amp; Quellen
            </a>
            <a href={withBase('/timeline')} class="btn btn--ghost btn--sm">
              Zur Timeline →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<!-- ================================================================
     PAGE-SPECIFIC STYLES (scoped by Astro)
     ================================================================ -->
<style>

  /* ------------------------------------------------------------------
     HERO
     ------------------------------------------------------------------ */
  .cg-hero {
    background-color: var(--clr-bg-alt);
    padding-block: var(--space-3xl) var(--space-2xl);
    border-bottom: 1px solid var(--clr-border);
  }

  .cg-hero__inner {
    max-width: 900px;
  }

  .cg-hero__title-block {
    margin-bottom: var(--space-xl);
  }

  .cg-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 400;
    color: var(--clr-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--space-xs);
  }

  .cg-hero__title-ar {
    font-family: var(--font-arabic);
    font-size: clamp(1.2rem, 2.5vw, 1.7rem);
    direction: rtl;
    text-align: right;
    color: var(--clr-text-muted);
    display: block;
    line-height: 1.5;
    max-width: none;
    margin: 0;
  }

  .cg-hero__intro {
    font-size: 0.975rem;
    line-height: 1.72;
    color: var(--clr-text-mid);
    max-width: 68ch;
    margin-bottom: var(--space-xl);
  }

  /* Quick-jump anchor nav */
  .cg-hero__anchors {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .cg-anchor-link {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    background-color: var(--clr-card);
    gap: 1px;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
    min-width: 7rem;
  }

  .cg-anchor-link:hover {
    border-color: var(--clr-olive);
    background-color: var(--clr-bg-alt);
  }

  .cg-anchor-link__ar {
    font-family: var(--font-arabic);
    font-size: 1rem;
    direction: rtl;
    color: var(--clr-text);
    line-height: 1.4;
  }

  .cg-anchor-link__de {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: var(--clr-text-muted);
    font-style: italic;
  }

  /* ------------------------------------------------------------------
     METHODISCHE EINLEITUNG
     ------------------------------------------------------------------ */
  .cg-method-intro {
    border-bottom: 1px solid var(--clr-border);
  }

  .cg-method-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .cg-method-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--clr-text);
    margin-top: var(--space-xs);
  }

  .cg-method-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg) var(--space-2xl);
  }

  .cg-method-point {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  .cg-method-point__num {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--clr-text-subtle);
    background-color: var(--clr-bg-alt);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    width: 1.8rem;
    height: 1.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-style: normal;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .cg-method-point p {
    font-size: 0.875rem;
    color: var(--clr-text-mid);
    line-height: 1.7;
    margin: 0;
    max-width: none;
  }

  /* ------------------------------------------------------------------
     GALLERY GRID
     ------------------------------------------------------------------ */
  .cg-cards-section {
    border-bottom: 1px solid var(--clr-border);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  /* Primary concept (الشرعية) spans full width */
  .gallery-card--primary {
    grid-column: 1 / -1;
  }

  /* ------------------------------------------------------------------
     GALLERY CARD
     ------------------------------------------------------------------ */
  .gallery-card {
    background-color: var(--clr-card);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition-mid);
    scroll-margin-top: 5rem; /* for anchor navigation */
  }

  .gallery-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  /* Left accent stripe — uses --card-accent CSS variable */
  .gallery-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 5px;
    background-color: var(--card-accent, var(--clr-olive));
  }

  /* Internal padding, offset by the left stripe */
  .gallery-card > * {
    padding-inline: var(--space-xl) var(--space-xl);
  }

  .gallery-card > *:first-child {
    padding-top: var(--space-xl);
  }

  .gallery-card > *:last-child {
    padding-bottom: var(--space-xl);
  }

  /* Card header */
  .gallery-card__header {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-md);
    align-items: start;
    border-bottom: 1px solid var(--clr-border-light);
    padding-bottom: var(--space-lg);
    margin-bottom: 0;
  }

  .gallery-card__num {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--clr-text-subtle);
    font-style: italic;
    padding-top: var(--space-xs);
    line-height: 1;
  }

  .gallery-card__identity {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gallery-card__ar {
    font-family: var(--font-arabic);
    font-size: 2rem;
    direction: rtl;
    text-align: right;
    color: var(--clr-text);
    line-height: 1.25;
    font-weight: 500;
    display: block;
  }

  .gallery-card__translit {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-style: italic;
    color: var(--clr-text-muted);
    text-align: right;
    display: block;
  }

  .gallery-card__de {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--clr-text);
    margin-top: var(--space-xs);
    padding-top: var(--space-xs);
    border-top: 1px solid var(--clr-border-light);
  }

  /* For the primary (full-width) card: larger Arabic term */
  .gallery-card--primary .gallery-card__ar  { font-size: 2.5rem; }
  .gallery-card--primary .gallery-card__de  { font-size: 1.65rem; }

  /* Generic section inside card */
  .gallery-card__section {
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--clr-border-light);
  }

  .gallery-card__section:last-of-type {
    border-bottom: none;
  }

  .gallery-card__question {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--clr-text);
    line-height: 1.55;
    margin-top: var(--space-xs);
    max-width: 60ch;
  }

  .gallery-card--primary .gallery-card__question {
    font-size: 1.15rem;
    max-width: 70ch;
  }

  .gallery-card__desc {
    font-size: 0.875rem;
    color: var(--clr-text-mid);
    line-height: 1.72;
    margin-top: var(--space-xs);
    max-width: none;
  }

  /* Phase relevance table */
  .gallery-phase-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: var(--space-sm);
    border: 1px solid var(--clr-border-light);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .gallery-phase-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--space-md);
    align-items: start;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--clr-border-light);
    background-color: var(--clr-bg);
  }

  .gallery-phase-row:last-child {
    border-bottom: none;
  }

  .gallery-phase-badge {
    /* Override default phase-badge margin */
    margin: 0;
    font-size: 0.65rem;
    align-self: start;
    margin-top: 2px;
  }

  .gallery-phase-text {
    font-size: 0.82rem;
    color: var(--clr-text-mid);
    line-height: 1.55;
    margin: 0;
    max-width: none;
  }

  /* Theory block */
  .gallery-theory-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .gallery-theory-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-sm);
    align-items: start;
  }

  .gallery-theory-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--clr-olive);
    text-transform: uppercase;
    padding-top: 2px;
    white-space: nowrap;
  }

  .gallery-theory-text {
