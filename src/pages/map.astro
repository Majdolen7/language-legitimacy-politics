---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegitimacyMap from '../components/LegitimacyMap.astro';
import { t } from '../i18n/translations';

const locale = 'de';
---

<BaseLayout
  title={t(locale, 'map.title')}
  description={t(locale, 'map.intro')}
  locale={locale}
>
  <section class="map-page" aria-labelledby="map-page-title">
    <div class="map-page__header">
      <span class="map-page__scope">{t(locale, 'map.scope')}</span>
      <h1 class="map-page__title" id="map-page-title">
        {t(locale, 'map.title')}
      </h1>
      <p class="map-page__intro">
        {t(locale, 'map.intro')}
      </p>
    </div>

    <div class="container">

      <!-- Methodology note 1: Spatial context, not speech locations -->
      <div class="map-page__method-note" role="note" aria-label="Methodologische Hinweise">
        <strong>Zur räumlichen Einordnung:</strong> Diese Karte visualisiert geografische Kontexte
        politischer Legitimitätsverschiebungen — nicht die Standorte, von denen aus Reden gehalten wurden.
        Für Corpus-Items wird der Kontext, nicht der Aufnahmeort, kartiert. Standortangaben sind mit
        Genauigkeitsstufen versehen (exakt / Stadtebene / Provinz).
      </div>

      <!-- Methodology note 2: Context events vs corpus items -->
      <div class="map-page__method-note" role="note">
        <strong>Corpus-Items vs. Kontext-Ereignisse:</strong> Markierungen mit Corpus-IDs (z. B.
        S2022-008) entsprechen Primärquellen im analytischen Forschungscorpus. Alle anderen Ereignisse
        sind historische Kontextereignisse, die den analytischen Rahmen der drei Legitimitätsphasen
        illustrieren. Das Projekt legitimiert oder delegitimiert keine politischen Akteure — es
        untersucht, wie Legitimitätsansprüche sprachlich konstruiert und diskursiv verschoben wurden.
      </div>

      <LegitimacyMap locale={locale} />
    </div>
  </section>
</BaseLayout>
