---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../i18n/utils';

const locale = 'de';
---

<BaseLayout
  title="Kontakt"
  description="Kontakt und Projektkontext für das Digital-Humanities-Forschungsprojekt Language, Legitimacy & Politics."
  locale={locale}
>

<section class="section contact-hero">
  <div class="container">
    <span class="page-kicker">Projektkontext</span>
    <h1 class="page-title">Kontakt und Projektkontext</h1>
  </div>
</section>

<section class="section">
  <div class="container contact-body">

    <div class="contact-main">

      <div class="contact-block">
        <p>
          Dieses digitale Forschungsprojekt entstand im Rahmen des Kurses
          „Digital Humanities and Data Sustainability" bei Christian Casey.
        </p>
        <p>
          Das Projekt untersucht, wie politische Legitimität im syrischen Kontext
          nach 2011 sprachlich konstruiert, verschoben und medial gerahmt wird.
          Es verbindet Diskursanalyse, Quellenkritik und digitale Methoden wie
          Timeline, Karte und ein kuratiertes Legitimacy Museum.
        </p>
      </div>

      <div class="contact-cv">
        <a
          href="https://majdolen7.github.io/academic-cv/"
          class="btn btn--outline contact-cv__btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Digital CV öffnen ↗
        </a>
      </div>

    </div>

    <aside class="contact-sidebar">
      <div class="contact-sidebar-card">
        <p class="contact-sidebar-card__label">Kurs</p>
        <p class="contact-sidebar-card__val">Digital Humanities and Data Sustainability</p>
      </div>
      <div class="contact-sidebar-card">
        <p class="contact-sidebar-card__label">Dozent</p>
        <p class="contact-sidebar-card__val">Christian Casey</p>
      </div>
      <div class="contact-sidebar-card">
        <p class="contact-sidebar-card__label">Projektseiten</p>
        <a href={withBase('/research-question')} class="contact-sidebar-link">Forschungsfrage →</a>
        <a href={withBase('/methodology')} class="contact-sidebar-link">Methodologie →</a>
        <a href={withBase('/legitimacy-museum')} class="contact-sidebar-link">Legitimacy Museum →</a>
      </div>
    </aside>

  </div>
</section>

</BaseLayout>

<style>
.contact-hero {
  background: var(--clr-bg-alt);
  border-bottom: 1px solid var(--clr-border);
  padding-bottom: var(--space-2xl);
}
.contact-body {
  display: grid;
  grid-template-columns: 1fr 16rem;
  gap: var(--space-3xl);
  align-items: start;
}
.contact-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-2xl);
}
.contact-block p {
  font-family: var(--font-sans);
  font-size: 0.9rem;
  color: var(--clr-text-mid);
  line-height: 1.75;
  margin-bottom: var(--space-md);
}
.contact-block p:last-child { margin-bottom: 0; }
.contact-cv { padding-top: var(--space-md); }
.contact-cv__btn { font-size: 0.8rem; }
.contact-sidebar {
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
  position: sticky;
  top: calc(3.5rem + var(--space-xl));
}
.contact-sidebar-card {
  background: var(--clr-bg-alt);
  border: 1px solid var(--clr-border-light);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
}
.contact-sidebar-card__label {
  font-family: var(--font-sans);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--clr-text-muted);
  margin-bottom: var(--space-sm);
  display: block;
}
.contact-sidebar-card__val {
  font-family: var(--font-sans);
  font-size: 0.82rem;
  color: var(--clr-text-mid);
  line-height: 1.5;
}
.contact-sidebar-link {
  display: block;
  font-family: var(--font-sans);
  font-size: 0.82rem;
  color: var(--clr-olive);
  text-decoration: none;
  margin-top: var(--space-sm);
}
.contact-sidebar-link:hover { color: var(--clr-red); }
@media (max-width: 900px) {
  .contact-body { grid-template-columns: 1fr; }
  .contact-sidebar { position: static; }
}
</style>
