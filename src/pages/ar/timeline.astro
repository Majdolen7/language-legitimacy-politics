---
import BaseLayout from '../../layouts/BaseLayout.astro';
import timelineData from '../../data/timeline.json';
import { t } from '../../i18n/translations';

const locale = 'ar';

const PHASE_COLORS: Record<number, string> = {
  1: '#8B5038',
  2: '#2F4A3C',
  3: '#4A5C38',
  4: '#2A3848',
};
---

<BaseLayout
  title="الخط الزمني"
  description="مراحل تحول أحمد الشرع من جبهة النصرة (2013) إلى السلطة الانتقالية السورية (2024–): أربع مراحل تحليلية مع المفاهيم والاستراتيجيات."
  locale={locale}
>

<section class="section tl-hero">
  <div class="container">
    <span class="page-kicker">مراحل الحوكمة والخطاب</span>
    <h1 class="tl-hero__title">الخط الزمني</h1>
    <p class="tl-hero__intro">
      أربع مراحل تحليلية من 2011 إلى 2026 — مع المفاهيم الرئيسية وأنواع الشرعية وملاحظات تحليلية.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">

    {timelineData.map((phase) => (
      <article class="tl-phase" id={`phase-${phase.phase_number}`}>

        <div class="tl-phase__header" style={`border-right-color: ${PHASE_COLORS[phase.phase_number]};`}>
          <div class="tl-phase__meta">
            <span class="tl-phase__years" style={`color: ${PHASE_COLORS[phase.phase_number]};`} dir="ltr">
              {phase.year_range}
            </span>
            <span class="tl-phase__num">المرحلة {phase.phase_number}</span>
          </div>
          <h2 class="tl-phase__title">{phase.phase_title_ar}</h2>
          <p class="tl-phase__subtitle-de" lang="de" dir="ltr">{phase.phase_subtitle_de}</p>
        </div>

        <div class="tl-phase__body">

          <div class="tl-phase__note">
            <span class="content-original-label">{t(locale, 'content.source-label-de')}</span>
            <p lang="de" dir="ltr">{phase.analytical_note_de}</p>
          </div>

          <div class="tl-phase__meta-grid">

            <div class="tl-meta-block">
              <p class="tl-meta-block__label">أنواع الشرعية</p>
              <span class="tl-meta-tag">{phase.legitimacy_type_dominant.replace(/_/g, ' ')}</span>
            </div>

            <div class="tl-meta-block">
              <p class="tl-meta-block__label">المفاهيم الرئيسية</p>
              <div class="tl-concepts">
                {phase.dominant_concepts.map(c => (
                  <div class="tl-concept">
                    <span lang="ar">{c.arabic}</span>
                    <span class="tl-concept__de" lang="de">{c.german}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="tl-meta-block">
              <p class="tl-meta-block__label">تسميات الطرف</p>
              <div class="tl-names">
                {phase.actor_naming_ar.map((name, i) => (
                  <div class="tl-name-item">
                    <span lang="ar">{name}</span>
                    {phase.actor_naming_de[i] && (
                      <span class="tl-name-de" lang="de" dir="ltr">{phase.actor_naming_de[i]}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {phase.key_events && (
              <div class="tl-meta-block">
                <p class="tl-meta-block__label">أحداث رئيسية</p>
                <ul class="tl-events">
                  {phase.key_events.map(ev => (
                    <li class="tl-event">
                      <span class="tl-event__year" dir="ltr">{ev.year}</span>
                      <span>{ev.event_ar}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

          </div>
        </div>
      </article>
    ))}

  </div>
</section>

</BaseLayout>

<style>
.tl-hero { background: var(--clr-bg-alt); border-bottom: 1px solid var(--clr-border); padding-bottom: var(--space-2xl); }
.tl-hero__title { font-family: var(--font-arabic); font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 500; color: var(--clr-text); }
.tl-hero__intro { font-family: var(--font-arabic); font-size: 1rem; color: var(--clr-text-mid); line-height: 1.85; margin-top: var(--space-md); }
.tl-phase { border: 1px solid var(--clr-border); border-radius: var(--radius-lg); background: var(--clr-card); margin-bottom: var(--space-2xl); overflow: hidden; }
.tl-phase__header { padding: var(--space-2xl); background: var(--clr-bg-alt); border-bottom: 1px solid var(--clr-border-light); border-right: 5px solid var(--clr-olive); padding-right: var(--space-2xl); }
.tl-phase__meta { display: flex; align-items: center; gap: var(--space-md); justify-content: flex-end; margin-bottom: var(--space-sm); flex-direction: row-reverse; }
.tl-phase__years { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.07em; }
.tl-phase__num { font-family: var(--font-arabic); font-size: 0.8rem; color: var(--clr-text-muted); background: var(--clr-bg); border: 1px solid var(--clr-border); border-radius: 20px; padding: 2px 10px; }
.tl-phase__title { font-family: var(--font-arabic); font-size: 1.3rem; font-weight: 500; color: var(--clr-text); line-height: 1.35; }
.tl-phase__subtitle-de { font-family: var(--font-serif); font-size: 0.9rem; color: var(--clr-text-muted); font-style: italic; margin-top: var(--space-xs); }
.tl-phase__body { display: grid; grid-template-columns: 1fr 18rem; gap: var(--space-2xl); padding: var(--space-2xl); }
.tl-phase__note p { font-family: var(--font-sans); font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.75; }
.tl-phase__meta-grid { display: flex; flex-direction: column; gap: var(--space-xl); }
.tl-meta-block__label { font-family: var(--font-arabic); font-size: 0.75rem; font-weight: 600; color: var(--clr-text-subtle); letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: var(--space-sm); }
.tl-meta-tag { font-family: var(--font-sans); font-size: 0.78rem; background: var(--clr-bg-alt); border: 1px solid var(--clr-border); border-radius: var(--radius-sm); padding: 2px 8px; color: var(--clr-text-muted); display: inline-block; }
.tl-concepts { display: flex; flex-direction: column; gap: 4px; }
.tl-concept { display: flex; justify-content: space-between; align-items: center; gap: var(--space-sm); padding: 3px var(--space-sm); background: var(--clr-bg-alt); border-radius: var(--radius-sm); }
.tl-concept span { font-family: var(--font-arabic); font-size: 0.9rem; color: var(--clr-text); }
.tl-concept__de { font-family: var(--font-sans); font-size: 0.72rem; color: var(--clr-text-muted); }
.tl-names { display: flex; flex-direction: column; gap: 4px; }
.tl-name-item { display: flex; flex-direction: column; gap: 2px; padding: 3px var(--space-sm); background: var(--clr-bg-alt); border-radius: var(--radius-sm); font-family: var(--font-arabic); font-size: 0.88rem; color: var(--clr-text); }
.tl-name-de { font-family: var(--font-sans); font-size: 0.72rem; color: var(--clr-text-muted); }
.tl-events { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
.tl-event { display: grid; grid-template-columns: 3rem 1fr; gap: var(--space-sm); align-items: baseline; font-family: var(--font-arabic); font-size: 0.85rem; color: var(--clr-text-mid); }
.tl-event__year { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; color: var(--clr-olive); }
@media (max-width: 760px) { .tl-phase__body { grid-template-columns: 1fr; } }
</style>
