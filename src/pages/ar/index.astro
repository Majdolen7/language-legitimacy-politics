---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../i18n/utils';

const locale = 'ar';
---

<BaseLayout
  title="اللغة والشرعية والسياسة"
  description="مشروع بحثي رقمي حول البناء الخطابي للشرعية السياسية في السياق السوري بعد عام 2011. أحمد الشرع بوصفه دراسة حالة."
  locale={locale}
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">

        <div class="hero__text">
          <p class="hero__overline">بحث رقمي في الخطاب السياسي السوري بعد عام 2011</p>

          <h1 class="hero__title">
            اللغة والبناء الخطابي للشرعية السياسية في سوريا المعاصرة
          </h1>

          <p class="hero__subtitle">أحمد الشرع بوصفه دراسة حالة</p>

          <div class="hero__rule" aria-hidden="true"></div>

          <p class="hero__intro">
            يدرس هذا المشروع كيف تُبنى الشرعية السياسية لغوياً وخطابياً وتُعاد صياغتها في الخطابات
            العامة والمقابلات والظهور السياسي. يُمثّل أحمد الشرع دراسةَ حالة لتتبّع هذه التحولات
            الخطابية في السياق السوري بعد عام 2011.
          </p>

          <div class="hero-phases" role="list" aria-label="ثلاث مراحل لتحولات الشرعية">
            <p class="hero-phases__label">ثلاث مراحل لتحولات الشرعية</p>
            <div class="hero-phases__track" dir="ltr">
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2011–2016</span>
                <span class="hero-phases__name">دينية–عسكرية</span>
              </div>
              <div class="hero-phases__connector" aria-hidden="true"></div>
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2017–2024</span>
                <span class="hero-phases__name">حوكمة / إدارة</span>
              </div>
              <div class="hero-phases__connector" aria-hidden="true"></div>
              <div class="hero-phases__phase" role="listitem">
                <span class="hero-phases__diamond" aria-hidden="true"></span>
                <span class="hero-phases__year">2025–2026</span>
                <span class="hero-phases__name">مؤسسية / دولتية</span>
              </div>
            </div>
          </div>

          <div class="hero__actions">
            <a href={withBase('/ar/research-question')} class="btn btn--primary">
              المشروع والمنهجية
            </a>
            <a href={withBase('/ar/legitimacy-museum')} class="btn btn--outline hero__btn-secondary">
              متحف الشرعية
            </a>
          </div>
        </div>

        <div class="hero__visual" aria-hidden="true">
          <div class="hero__visual-paper"></div>
          <div class="hero__visual-burgundy"></div>
          <div class="hero__visual-circle-large"></div>
          <div class="hero__visual-circle-small"></div>

          <div class="hero__podium-wrap">
            <svg
              class="hero__podium-svg"
              viewBox="0 0 220 310"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-label="منبر مع ميكروفونات"
            >
              <ellipse cx="110" cy="304" rx="88" ry="6" fill="#241C18" opacity="0.10"/>
              <path d="M 42 128 L 178 128 L 195 292 L 25 292 Z" fill="#2A1810"/>
              <rect x="36" y="112" width="148" height="22" rx="2" fill="#3A2218"/>
              <rect x="36" y="112" width="148" height="4" rx="2" fill="#4E3025" opacity="0.7"/>
              <line x1="68" y1="196" x2="152" y2="196" stroke="#B28757" stroke-width="1.5" opacity="0.65"/>
              <line x1="78" y1="203" x2="142" y2="203" stroke="#B28757" stroke-width="0.8" opacity="0.4"/>
              <rect x="101" y="174" width="18" height="14" rx="1" fill="none" stroke="#B28757" stroke-width="1" opacity="0.45"/>
              <line x1="88" y1="112" x2="82" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="79" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="79" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <line x1="132" y1="112" x2="138" y2="32" stroke="#1C0E08" stroke-width="2.5" stroke-linecap="round"/>
              <ellipse cx="141" cy="20" rx="9" ry="14" fill="#1C0E08"/>
              <ellipse cx="141" cy="17" rx="5" ry="4" fill="#2A1810" opacity="0.5"/>
              <rect x="16" y="290" width="188" height="10" rx="2" fill="#1C0E08" opacity="0.85"/>
              <rect x="26" y="286" width="168" height="6" rx="1" fill="#2A1810"/>
            </svg>
          </div>

          <div class="hero__visual-dots"></div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       2. THREE ANALYTICAL DIMENSIONS
       ============================================================ -->
  <section class="section dimensions-section" aria-labelledby="dimensions-title">
    <div class="container">

      <div class="dimensions-header">
        <span class="section-overline">النموذج التحليلي</span>
        <h2 class="dimensions-title" id="dimensions-title">
          ثلاثة أبعاد للشرعية السياسية
        </h2>
        <p class="dimensions-intro">
          تُبنين الأبعاد الثلاثة المتن بنيةً تحليلية. تستند إلى المراحل الثلاث
          دون أن تُشكّل تاريخاً مكتملاً للأحداث في سياق النزاع السوري.
        </p>
      </div>

      <div class="dim-grid">

        <article class="dim-card dim-card--1">
          <div class="dim-card__phase" dir="ltr">2011–2016</div>
          <h3 class="dim-card__title">الشرعية الدينية–العسكرية</h3>
          <p class="dim-card__desc">
            السلطة الفصائلية والتأطير الديني–العسكري وشبكات الجهاد والبيعة
            بوصفها مصادر للإضفاء الشرعي.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">الجهاد</span>
            <span class="dim-indicator">البيعة</span>
            <span class="dim-indicator">الأمة</span>
            <span class="dim-indicator">الشريعة</span>
          </div>
        </article>

        <article class="dim-card dim-card--2">
          <div class="dim-card__phase" dir="ltr">2017–2024</div>
          <h3 class="dim-card__title">الشرعية الإدارية / شرعية الحوكمة</h3>
          <p class="dim-card__desc">
            إدلب بوصفها مركزاً للحوكمة، والأداء الإداري والأمن بوصفهما مصادر
            للشرعية الخطابية — هيئة تحرير الشام بوصفها فاعلاً إدارياً.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">الإدارة</span>
            <span class="dim-indicator">الأمن</span>
            <span class="dim-indicator">النظام</span>
            <span class="dim-indicator">الاستقرار</span>
          </div>
        </article>

        <article class="dim-card dim-card--3">
          <div class="dim-card__phase" dir="ltr">2025–2026</div>
          <h3 class="dim-card__title">الشرعية المؤسسية / الدولتية</h3>
          <p class="dim-card__desc">
            لغة الدولة والوحدة الوطنية والمواطنة والاعتراف الدولي
            بوصفها إطاراً للإضفاء الشرعي للسلطة الانتقالية.
          </p>
          <div class="dim-card__indicators">
            <span class="dim-indicator">الدولة</span>
            <span class="dim-indicator">المواطنة</span>
            <span class="dim-indicator">الاعتراف</span>
            <span class="dim-indicator">المؤسسات</span>
          </div>
        </article>

      </div>

      <p class="dimensions-footer-link">
        <a href={withBase('/ar/timeline')} class="btn btn--ghost btn--sm">
          الخط الزمني التحليلي الكامل ←
        </a>
      </p>

    </div>
  </section>


  <!-- ============================================================
       3. RESEARCH FOCUS
       ============================================================ -->
  <section class="section research-focus-section" aria-labelledby="research-focus-title">
    <div class="container">

      <div class="research-focus-inner">

        <div class="research-focus-heading">
          <span class="section-overline">محور البحث</span>
          <h2 class="research-focus-title" id="research-focus-title">
            الشرعية السياسية بوصفها موضوعًا بحثيًا
          </h2>
        </div>

        <div class="research-focus-body">
          <p class="research-focus-text">
            لا يتناول المشروع سيرة فاعل سياسي، بل يُعنى بالسؤال عن كيفية إنتاج الشرعية السياسية
            لغوياً. يجمع المشروع بين تحليل الخطاب ونقد المصادر والنمذجة الرقمية: يُوثّق المتن
            المواد، ويُبنين الخط الزمني المراحل الخطابية، وتُصوّر الخريطة السياقات المكانية
            لمطالب الشرعية السياسية.
          </p>
          <div class="research-focus-pillars">
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">I</span>
              <div>
                <strong class="research-pillar__label">الموضوع المحوري</strong>
                <p class="research-pillar__desc">الشرعية السياسية — بوصفها نظاماً مُبنى لغوياً وخطابياً</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">II</span>
              <div>
                <strong class="research-pillar__label">المقاربة التحليلية</strong>
                <p class="research-pillar__desc">تحليل اللغة والخطاب — كيف تُبنى الشرعية وتتحول وتُعاد صياغتها</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">III</span>
              <div>
                <strong class="research-pillar__label">دراسة الحالة</strong>
                <p class="research-pillar__desc">أحمد الشرع — بوصفه حالةً لا سيرة شخصية</p>
              </div>
            </div>
            <div class="research-pillar">
              <span class="research-pillar__icon" aria-hidden="true">IV</span>
              <div>
                <strong class="research-pillar__label">الأدوات الرقمية</strong>
                <p class="research-pillar__desc">المتن والخط الزمني والخريطة بوصفها أدوات للإنسانيات الرقمية</p>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>


  <!-- ============================================================
       4. DIGITAL TOOLS
       ============================================================ -->
  <section class="section tools-section" aria-labelledby="tools-title">
    <div class="container">

      <span class="section-overline">أدوات البحث</span>
      <h2 class="section-title tools-section__title" id="tools-title">الأدوات الرقمية للمشروع</h2>

      <div class="tools-grid">

        <a href={withBase('/ar/legitimacy-museum')} class="tool-card">
          <span class="tool-card__eyebrow">أرشيف رقمي</span>
          <h3 class="tool-card__title">متحف الشرعية</h3>
          <p class="tool-card__desc">
            فهرس منسَّق للمصادر الأولية مع حالة التحقق والمراجع
            والملاحظات البحثية المتاحة للعموم.
          </p>
          <span class="tool-card__link" aria-hidden="true">←</span>
        </a>

        <a href={withBase('/ar/map')} class="tool-card">
          <span class="tool-card__eyebrow">خريطة تفاعلية</span>
          <h3 class="tool-card__title">خريطة الشرعية السياسية</h3>
          <p class="tool-card__desc">
            السياقات المكانية لتحولات الشرعية السياسية — من الثورة السورية
            إلى السلطة الانتقالية.
          </p>
          <span class="tool-card__link" aria-hidden="true">←</span>
        </a>

        <a href={withBase('/ar/timeline')} class="tool-card">
          <span class="tool-card__eyebrow">خط زمني تحليلي</span>
          <h3 class="tool-card__title">الخط الزمني والمنهجية</h3>
          <p class="tool-card__desc">
            ثلاث مراحل تحليلية وتحولات خطابية وتسميات الأطراف
            واستراتيجيات الإضفاء الشرعي في نظرة شاملة.
          </p>
          <span class="tool-card__link" aria-hidden="true">←</span>
        </a>

      </div>

    </div>
  </section>


  <!-- ============================================================
       5. CASE STUDY
       ============================================================ -->
  <section class="section case-study-section" aria-labelledby="case-study-title">
    <div class="container">
      <div class="case-study-inner">

        <div class="case-study-heading">
          <span class="section-overline">دراسة الحالة</span>
          <h2 class="section-title case-study-title" id="case-study-title">
            أحمد الشرع بوصفه دراسة حالة
          </h2>
        </div>

        <div class="case-study-body">
          <p class="case-study-text">
            أحمد الشرع ليس موضوع هذا المشروع الكلي. إنه الحالة التي يُتتبَّع من خلالها
            التحول الخطابي للشرعية السياسية. لا يتناول المشروع السيرة الشخصية،
            بل السؤال: كيف تُبنى مطالب الشرعية لغوياً وتُخرَج إعلامياً وتُسيَّق مكانياً؟
          </p>
          <a href={withBase('/ar/actor-transformation')} class="btn btn--outline">
            تسمية الطرف بوصفها مؤشراً على الشرعية ←
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<style>

  /* ------------------------------------------------------------------
     HERO (RTL-adapted)
     ------------------------------------------------------------------ */
  .hero {
    background-color: #FFFFFF;
    padding-block: var(--space-3xl) var(--space-2xl);
    border-bottom: 1px solid var(--clr-border-light);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero__text {
    max-width: 640px;
    margin-inline-start: auto;
  }

  .hero__overline {
    font-family: var(--font-arabic);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--clr-red);
    margin-bottom: var(--space-lg);
    display: block;
  }

  .hero__title {
    font-family: var(--font-arabic);
    font-size: clamp(1.8rem, 3.8vw, 2.8rem);
    font-weight: 500;
    color: var(--clr-text);
    line-height: 1.3;
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-family: var(--font-arabic);
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    font-weight: 400;
    font-style: normal;
    color: var(--clr-text-mid);
    line-height: 1.5;
    margin-bottom: var(--space-lg);
  }

  .hero__rule {
    width: 3rem;
    height: 2px;
    background-color: var(--clr-gold);
    margin-bottom: var(--space-lg);
    border-radius: 1px;
    margin-inline-start: auto;
  }

  .hero__intro {
    font-family: var(--font-arabic);
    font-size: 0.975rem;
    line-height: 1.85;
    color: var(--clr-text-mid);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
    margin-inline-start: auto;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
    justify-content: flex-end;
  }

  .hero__btn-secondary {
    font-size: 0.78rem;
    padding: var(--space-sm) var(--space-md);
  }

  /* Visual */
  .hero__visual {
    position: relative;
    height: 420px;
    flex-shrink: 0;
    order: -1;
  }

  .hero__visual-paper {
    position: absolute;
    inset: 0;
    background-color: #EBE4DC;
    border-radius: 2px;
    opacity: 0.55;
  }

  .hero__visual-burgundy {
    position: absolute;
    top: 0;
    left: 0;
    width: 48%;
    height: 44%;
    background-color: #8B2635;
    opacity: 0.60;
  }

  .hero__visual-circle-large {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-42%, -52%);
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background-color: #E0D8D0;
    opacity: 0.45;
  }

  .hero__visual-circle-small {
    position: absolute;
    top: 38%;
    left: 8%;
    transform: translateY(-40%);
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background-color: #D4C9C0;
    opacity: 0.35;
  }

  .hero__podium-wrap {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 190px;
    z-index: 2;
  }

  .hero__podium-svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 3px 10px rgba(36,28,24,0.14));
  }

  .hero__visual-dots {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    width: 80px;
    height: 80px;
    background-image: radial-gradient(#B28757 1.2px, transparent 1.2px);
    background-size: 11px 11px;
    opacity: 0.45;
    z-index: 1;
  }

  /* ------------------------------------------------------------------
     THREE ANALYTICAL DIMENSIONS
     ------------------------------------------------------------------ */
  .dimensions-section {
    background-color: #FFFFFF;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .dimensions-header {
    max-width: 700px;
    margin-bottom: var(--space-2xl);
    margin-inline-start: auto;
  }

  .dimensions-title {
    font-family: var(--font-arabic);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 500;
    color: var(--clr-text);
    line-height: 1.3;
    margin: var(--space-xs) 0 var(--space-md);
  }

  .dimensions-intro {
    font-family: var(--font-arabic);
    font-size: 0.9rem;
    color: var(--clr-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .dim-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .dim-card {
    background-color: #FFFFFF;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--transition-mid);
  }

  .dim-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .dim-card--1 { border-top: 4px solid #8B2635; }
  .dim-card--2 { border-top: 4px solid #4A2E22; }
  .dim-card--3 { border-top: 4px solid #2A3848; }

  .dim-card__phase {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--clr-text-muted);
    text-transform: uppercase;
    text-align: left;
  }

  .dim-card__title {
    font-family: var(--font-arabic);
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 500;
    color: var(--clr-text);
    line-height: 1.4;
    margin: 0;
  }

  .dim-card__desc {
    font-family: var(--font-arabic);
    font-size: 0.88rem;
    color: var(--clr-text-mid);
    line-height: 1.75;
    flex: 1;
    margin: 0;
  }

  .dim-card__indicators {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-xs);
    justify-content: flex-end;
  }

  .dim-indicator {
    font-family: var(--font-arabic);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 2px 8px;
    background-color: var(--clr-bg);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    color: var(--clr-text-muted);
    white-space: nowrap;
  }

  .dimensions-footer-link {
    margin-top: var(--space-2xl);
    text-align: center;
    margin-bottom: 0;
  }

  /* ------------------------------------------------------------------
     RESEARCH FOCUS
     ------------------------------------------------------------------ */
  .research-focus-section {
    background-color: #FAF8F5;
    border-bottom: 1px solid var(--clr-border-light);
  }

  .research-focus-inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .research-focus-title {
    font-family: var(--font-arabic);
    font-size: clamp(1.3rem, 3vw, 1.85rem);
    font-weight: 500;
    color: var(--clr-text);
    line-height: 1.35;
    margin-top: var(--space-xs);
  }

  .research-focus-text {
    font-family: var(--font-arabic);
    font-size: 0.975rem;
    line-height: 1.85;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-xl);
    max-width: 62ch;
    margin-inline-start: auto;
  }

  .research-focus-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
