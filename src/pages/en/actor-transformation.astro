---
import BaseLayout from '../../layouts/BaseLayout.astro';
import timelineData from '../../data/timeline.json';
import { t } from '../../i18n/translations';

const locale = 'en';

const PHASE_COLORS: Record<number, string> = {
  1: '#8B5038',
  2: '#2F4A3C',
  3: '#4A5C38',
  4: '#2A3848',
};
---

<BaseLayout
  title="Actor Transformation"
  description="The discursive transformation of Ahmad al-Sharaa from Jabhat al-Nusra (2013) to the Syrian transitional government (2024): four phases, naming, legitimacy types."
  locale={locale}
>

<section class="section at-hero">
  <div class="container">
    <span class="page-kicker">From armed faction to transitional authority</span>
    <h1 class="page-title">Actor Transformation</h1>
    <p class="page-subtitle">Discursive transformation of Ahmad al-Sharaa / Hayʾat Taḥrīr al-Shām, 2011–2026</p>
  </div>
</section>

<section class="section at-names-section">
  <div class="container">
    <span class="section-overline">Self-designations in transformation</span>
    <h2 class="section-title">Actor and group naming by phase</h2>
    <p class="at-intro">
      A central feature of discursive transformation is the systematic change of the actor's
      and group's self-designation. Each renaming marks a strategic shift in the construction
      of political legitimacy.
    </p>

    <div class="at-names-grid">
      {timelineData.map((phase) => (
        <div class="at-name-card" style={`border-top-color: ${PHASE_COLORS[phase.phase_number]};`}>
          <div class="at-name-card__phase" style={`color: ${PHASE_COLORS[phase.phase_number]};`} dir="ltr">
            Phase {phase.phase_number} · {phase.year_range}
          </div>
          <h3 class="at-name-card__title" dir="ltr">{phase.phase_title_de}</h3>
          <p class="at-name-card__title-ar" lang="ar" dir="rtl">{phase.phase_title_ar}</p>
          <div class="at-name-card__names">
            {phase.actor_naming_de.map((name, i) => (
              <div class="at-name-item" dir="ltr">
                <span>{name}</span>
                {phase.actor_naming_ar[i] && (
                  <span class="at-name-item__ar" lang="ar" dir="rtl">{phase.actor_naming_ar[i]}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section section--alt at-phases-section">
  <div class="container">
    <span class="section-overline">Phase analysis</span>
    <h2 class="section-title">Legitimation strategies and key concepts</h2>

    {timelineData.map((phase) => (
      <article class="at-phase-block" id={`phase-${phase.phase_number}`}>
        <div class="at-phase-block__header">
          <div class="at-phase-block__num" style={`background-color: ${PHASE_COLORS[phase.phase_number]};`}>
            {phase.phase_number}
          </div>
          <div>
            <span class="at-phase-block__years" style={`color: ${PHASE_COLORS[phase.phase_number]};`} dir="ltr">
              {phase.year_range}
            </span>
            <h3 class="at-phase-block__title" dir="ltr">{phase.phase_title_de}</h3>
            <p class="at-phase-block__subtitle" dir="ltr">{phase.phase_subtitle_de}</p>
          </div>
        </div>

        <div class="at-phase-block__body">
          <div class="at-phase-block__note">
            <p dir="ltr" lang="de">{phase.analytical_note_de}</p>
            <span class="content-original-label">{t(locale, 'content.original-label')}</span>
          </div>

          <div class="at-phase-block__meta">
            <div class="at-phase-meta-row">
              <span class="at-phase-meta-key">Dominant legitimacy type</span>
              <span class="at-phase-meta-val" dir="ltr">{phase.legitimacy_type_dominant.replace(/_/g, ' ')}</span>
            </div>

            <div class="at-concepts-block">
              <p class="at-concepts-block__label">Key concepts</p>
              <div class="at-concepts-list">
                {phase.dominant_concepts.map(c => (
                  <div class="at-concept-item">
                    <span lang="ar" dir="rtl">{c.arabic}</span>
                    <span class="at-concept-item__de" dir="ltr">{c.german}</span>
                  </div>
                ))}
              </div>
            </div>

            {phase.key_events && phase.key_events.length > 0 && (
              <div class="at-events-block">
                <p class="at-events-block__label">Key events</p>
                <ul class="at-events-list">
                  {phase.key_events.map(ev => (
                    <li class="at-event-item" dir="ltr">
                      <span class="at-event-item__year">{ev.year}</span>
                      <span>{ev.event_de}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

</BaseLayout>

<style>
.at-hero { background: var(--clr-bg-alt); border-bottom: 1px solid var(--clr-border); padding-bottom: var(--space-2xl); }
.at-intro { font-family: var(--font-sans); font-size: 0.95rem; color: var(--clr-text-mid); line-height: 1.75; max-width: 65ch; margin-bottom: var(--space-2xl); }
.at-names-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-lg); }
.at-name-card { background: var(--clr-card); border: 1px solid var(--clr-border); border-radius: var(--radius-md); border-top: 4px solid var(--clr-olive); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-md); }
.at-name-card__phase { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.at-name-card__title { font-family: var(--font-serif); font-size: 1rem; font-weight: 400; color: var(--clr-text); line-height: 1.3; }
.at-name-card__title-ar { font-family: var(--font-arabic); font-size: 0.95rem; color: var(--clr-text-muted); line-height: 1.5; margin: 0; }
.at-name-card__names { display: flex; flex-direction: column; gap: var(--space-xs); margin-top: var(--space-xs); }
.at-name-item { display: flex; flex-direction: column; gap: 2px; padding: var(--space-xs) var(--space-md); background: var(--clr-bg-alt); border-radius: var(--radius-sm); border: 1px solid var(--clr-border-light); font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text); }
.at-name-item__ar { font-family: var(--font-arabic); font-size: 0.88rem; color: var(--clr-text-muted); display: block; }
.at-phases-section { border-top: 1px solid var(--clr-border); }
.at-phase-block { background: var(--clr-card); border: 1px solid var(--clr-border); border-radius: var(--radius-lg); padding: var(--space-2xl); margin-bottom: var(--space-xl); }
.at-phase-block__header { display: flex; gap: var(--space-xl); align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-xl); border-bottom: 1px solid var(--clr-border-light); }
.at-phase-block__num { display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 50%; color: white; font-family: var(--font-sans); font-size: 1rem; font-weight: 700; flex-shrink: 0; }
.at-phase-block__years { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; display: block; margin-bottom: 4px; }
.at-phase-block__title { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 400; color: var(--clr-text); margin-bottom: var(--space-xs); }
.at-phase-block__subtitle { font-family: var(--font-serif); font-size: 0.85rem; color: var(--clr-text-muted); font-style: italic; margin: 0; }
.at-phase-block__body { display: grid; grid-template-columns: 1fr 20rem; gap: var(--space-2xl); align-items: start; }
.at-phase-block__note p { font-family: var(--font-sans); font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.75; margin: 0 0 var(--space-sm); }
.at-phase-meta-row { display: flex; flex-direction: column; gap: 2px; margin-bottom: var(--space-md); }
.at-phase-meta-key { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: var(--clr-text-subtle); }
.at-phase-meta-val { font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text-mid); }
.at-concepts-block { margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--clr-border-light); }
.at-concepts-block__label, .at-events-block__label { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: var(--clr-text-subtle); margin-bottom: var(--space-sm); }
.at-concepts-list { display: flex; flex-direction: column; gap: 4px; }
.at-concept-item { display: flex; align-items: center; justify-content: space-between; gap: var(--space-sm); padding: 3px var(--space-sm); background: var(--clr-bg-alt); border-radius: var(--radius-sm); }
.at-concept-item span { font-family: var(--font-arabic); font-size: 0.9rem; color: var(--clr-text); }
.at-concept-item__de { font-family: var(--font-sans); font-size: 0.72rem; color: var(--clr-text-muted); }
.at-events-block { margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--clr-border-light); }
.at-events-list { display: flex; flex-direction: column; gap: var(--space-xs); list-style: none; padding: 0; margin: 0; }
.at-event-item { display: grid; grid-template-columns: 3rem 1fr; gap: var(--space-sm); align-items: baseline; font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text-mid); }
.at-event-item__year { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; color: var(--clr-olive); }
@media (max-width: 1100px) { .at-names-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 760px) { .at-names-grid { grid-template-columns: 1fr; } .at-phase-block__body { grid-template-columns: 1fr; } .at-phase-block__header { flex-direction: column; gap: var(--space-md); } }
</style>
