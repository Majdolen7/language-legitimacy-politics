---
import BaseLayout from '../../layouts/BaseLayout.astro';
import timelineData from '../../data/timeline.json';
const locale = 'en';

const PHASE_COLORS: Record<number, string> = {
  1: '#8B5038',
  2: '#2F4A3C',
  3: '#4A5C38',
  4: '#2A3848',
};
---

<BaseLayout
  title="Timeline"
  description="Four analytical phases of actor transformation from Jabhat al-Nusra (2013) to the Syrian transitional authority (2024–): key concepts, legitimacy types, and analytical notes."
  locale={locale}
>

<section class="section tl-hero">
  <div class="container">
    <span class="page-kicker">Phases of governance and discourse</span>
    <h1 class="tl-hero__title">Timeline</h1>
    <p class="tl-hero__intro">
      Four analytical phases from 2011 to 2026 — with key concepts, legitimacy types, and analytical notes.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    {timelineData.map((phase) => (
      <article class="tl-phase" id={`phase-${phase.phase_number}`}>

        <div class="tl-phase__header" style={`border-left-color: ${PHASE_COLORS[phase.phase_number]};`}>
          <div class="tl-phase__meta">
            <span class="tl-phase__years" style={`color: ${PHASE_COLORS[phase.phase_number]};`} dir="ltr">
              {phase.year_range}
            </span>
            <span class="tl-phase__num" dir="ltr">Phase {phase.phase_number}</span>
          </div>
          <h2 class="tl-phase__title">{phase.phase_title_en}</h2>
          <p class="tl-phase__subtitle" style="font-style: italic; color: var(--clr-text-muted);">{phase.phase_subtitle_en}</p>
          <p class="tl-phase__title-ar" lang="ar" dir="rtl">{phase.phase_title_ar}</p>
        </div>

        <div class="tl-phase__body">

          <div class="tl-phase__note">
            <p>{phase.analytical_note_en}</p>
          </div>

          <div class="tl-phase__meta-grid">

            <div class="tl-meta-block">
              <p class="tl-meta-block__label">Legitimacy type</p>
              <span class="tl-meta-tag" dir="ltr">{phase.legitimacy_type_dominant.replace(/_/g, ' ')}</span>
            </div>

            <div class="tl-meta-block">
              <p class="tl-meta-block__label">Key concepts</p>
              <div class="tl-concepts">
                {phase.dominant_concepts.map(c => (
                  <div class="tl-concept">
                    <span lang="ar" dir="rtl">{c.arabic}</span>
                    <span class="tl-concept__de" dir="ltr">{c.german}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="tl-meta-block">
              <p class="tl-meta-block__label">Actor naming</p>
              <div class="tl-names">
                {phase.actor_naming_en.map((name, i) => (
                  <div class="tl-name-item">
                    <span dir="ltr">{name}</span>
                    {phase.actor_naming_ar[i] && (
                      <span class="tl-name-ar" lang="ar" dir="rtl">{phase.actor_naming_ar[i]}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {phase.key_events && (
              <div class="tl-meta-block">
                <p class="tl-meta-block__label">Key events</p>
                <ul class="tl-events">
                  {phase.key_events.map(ev => (
                    <li class="tl-event">
                      <span class="tl-event__year" dir="ltr">{ev.year}</span>
                      <span dir="ltr">{ev.event_en}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

          </div>
        </div>
      </article>
    ))}
  </div>
</section>

</BaseLayout>

<style>
.tl-hero { background: var(--clr-bg-alt); border-bottom: 1px solid var(--clr-border); padding-bottom: var(--space-2xl); }
.tl-hero__title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 400; color: var(--clr-text); }
.tl-hero__intro { font-family: var(--font-sans); font-size: 1rem; color: var(--clr-text-mid); line-height: 1.75; margin-top: var(--space-md); }
.tl-phase { border: 1px solid var(--clr-border); border-radius: var(--radius-lg); background: var(--clr-card); margin-bottom: var(--space-2xl); overflow: hidden; }
.tl-phase__header { padding: var(--space-2xl); background: var(--clr-bg-alt); border-bottom: 1px solid var(--clr-border-light); border-left: 5px solid var(--clr-olive); }
.tl-phase__meta { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-sm); }
.tl-phase__years { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.07em; }
.tl-phase__num { font-family: var(--font-sans); font-size: 0.8rem; color: var(--clr-text-muted); background: var(--clr-bg); border: 1px solid var(--clr-border); border-radius: 20px; padding: 2px 10px; }
.tl-phase__title { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 400; color: var(--clr-text); line-height: 1.35; }
.tl-phase__title-ar { font-family: var(--font-arabic); font-size: 1rem; color: var(--clr-text-muted); font-weight: 400; line-height: 1.5; margin-top: var(--space-sm); }
.tl-phase__body { display: grid; grid-template-columns: 1fr 18rem; gap: var(--space-2xl); padding: var(--space-2xl); }
.tl-phase__note p { font-family: var(--font-sans); font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.75; }
.tl-phase__meta-grid { display: flex; flex-direction: column; gap: var(--space-xl); }
.tl-meta-block__label { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700; color: var(--clr-text-subtle); letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: var(--space-sm); }
.tl-meta-tag { font-family: var(--font-sans); font-size: 0.78rem; background: var(--clr-bg-alt); border: 1px solid var(--clr-border); border-radius: var(--radius-sm); padding: 2px 8px; color: var(--clr-text-muted); display: inline-block; }
.tl-concepts { display: flex; flex-direction: column; gap: 4px; }
.tl-concept { display: flex; justify-content: space-between; align-items: center; gap: var(--space-sm); padding: 3px var(--space-sm); background: var(--clr-bg-alt); border-radius: var(--radius-sm); }
.tl-concept span { font-family: var(--font-arabic); font-size: 0.9rem; color: var(--clr-text); }
.tl-concept__de { font-family: var(--font-sans); font-size: 0.72rem; color: var(--clr-text-muted); }
.tl-names { display: flex; flex-direction: column; gap: 4px; }
.tl-name-item { display: flex; flex-direction: column; gap: 2px; padding: 3px var(--space-sm); background: var(--clr-bg-alt); border-radius: var(--radius-sm); font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text); }
.tl-name-ar { font-family: var(--font-arabic); font-size: 0.85rem; color: var(--clr-text-muted); }
.tl-events { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
.tl-event { display: grid; grid-template-columns: 3rem 1fr; gap: var(--space-sm); align-items: baseline; font-family: var(--font-sans); font-size: 0.82rem; color: var(--clr-text-mid); }
.tl-event__year { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; color: var(--clr-olive); }
@media (max-width: 760px) { .tl-phase__body { grid-template-columns: 1fr; } }
</style>
