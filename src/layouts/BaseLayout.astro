---
import '../styles/global.css';
import '../styles/typography.css';
import '../styles/components.css';
import '../styles/arabic.css';
import '../styles/rtl.css';
import { t, type Locale } from '../i18n/translations';
import { getLocalePath, localeDir, withBase, BASE } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const {
  title,
  description,
  locale = 'de',
} = Astro.props;

const dir = localeDir(locale);
const lang = locale;
const currentPath = Astro.url.pathname;
// Strip the base prefix for internal comparisons (isActive, etc.)
const currentPathWithoutBase =
  BASE && currentPath.startsWith(BASE) ? currentPath.slice(BASE.length) || '/' : currentPath;

const defaultDesc = locale === 'de'
  ? 'Ein digitales Forschungsprojekt zu Legitimitäts- und Staatsdiskursen in Syrien nach 2011.'
  : locale === 'ar'
  ? 'مشروع بحثي رقمي حول خطابات الشرعية في سوريا بعد عام 2011.'
  : 'A digital research project on legitimacy discourses in Syria after 2011.';

const resolvedDescription = description ?? defaultDesc;

const siteTitle = 'Language, Legitimacy & Politics';
const fullTitle  = title === siteTitle ? title : `${title} | ${siteTitle}`;

// Equivalent paths for hreflang and switcher
const dePath = getLocalePath(currentPath, 'de');
const arPath = getLocalePath(currentPath, 'ar');
const enPath = getLocalePath(currentPath, 'en');

// Locale-prefixed nav
const prefix = locale === 'de' ? '' : `/${locale}`;

// Nav items per locale — AR/EN omit pages that have no locale version
const navItemsDE = [
  { href: '/',                          label: 'Startseite'        },
  { href: '/research-question',         label: 'Forschungsfrage'   },
  { href: '/timeline',                  label: 'Timeline'          },
  { href: '/concepts',                  label: 'Konzepte'          },
  { href: '/actor-transformation',      label: 'Akteurswandel'     },
  { href: '/cabinet',                   label: 'Regierung'         },
  { href: '/corpus',                    label: 'Corpus'            },
  { href: '/map',                       label: 'Map'               },
  { href: '/legitimacy-museum',         label: 'Legitimacy Museum' },
  { href: '/methodology',               label: 'Methodologie'      },
  { href: '/data-sustainability',       label: 'Daten'             },
];

const navItemsAR = [
  { href: '/ar/',                       label: t('ar', 'nav.home')               },
  { href: '/ar/research-question',      label: t('ar', 'nav.research-question')  },
  { href: '/ar/timeline',               label: t('ar', 'nav.timeline')           },
  { href: '/ar/actor-transformation',   label: t('ar', 'nav.actor-transformation') },
  { href: '/ar/corpus',                 label: t('ar', 'nav.corpus')             },
  { href: '/ar/map',                    label: t('ar', 'nav.map')                },
  { href: '/ar/legitimacy-museum',      label: t('ar', 'nav.legitimacy-museum')  },
  { href: '/ar/methodology',            label: t('ar', 'nav.methodology')        },
  { href: '/ar/about',                  label: t('ar', 'footer.about')           },
];

const navItemsEN = [
  { href: '/en/',                       label: 'Home'                },
  { href: '/en/research-question',      label: 'Research Question'   },
  { href: '/en/timeline',               label: 'Timeline'            },
  { href: '/en/actor-transformation',   label: 'Actor Transformation'},
  { href: '/en/corpus',                 label: 'Corpus'              },
  { href: '/en/map',                    label: 'Map'                 },
  { href: '/en/legitimacy-museum',      label: 'Legitimacy Museum'   },
  { href: '/en/methodology',            label: 'Methodology'         },
  { href: '/en/about',                  label: 'About'               },
];

const navItems = locale === 'de' ? navItemsDE : locale === 'ar' ? navItemsAR : navItemsEN;

function isActive(href: string): boolean {
  // Home links: exact match only
  if (href === '/' || href === '/ar/' || href === '/en/') {
    return currentPathWithoutBase === href || currentPathWithoutBase === href.replace(/\/$/, '');
  }
  return currentPathWithoutBase.startsWith(href);
}

// Footer links are locale-aware
const footerLinks = [
  { href: `${prefix}/about`,                label: t(locale, 'footer.about')       },
  { href: `${prefix}/methodology`,          label: t(locale, 'footer.methodology') },
  { href: `${prefix}/legitimacy-museum`,    label: t(locale, 'footer.museum')      },
  { href: `${prefix}/map`,                  label: t(locale, 'footer.map')         },
  { href: `${prefix}/data-sustainability`,  label: t(locale, 'footer.data')        },
];
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={resolvedDescription} />
  <meta name="generator" content={Astro.generator} />

  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={resolvedDescription} />
  <meta property="og:type"        content="website" />

  <title>{fullTitle}</title>

  <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

  <!-- Canonical and hreflang -->
  <link rel="canonical" href={currentPath} />
  <link rel="alternate" hreflang="de" href={dePath} />
  <link rel="alternate" hreflang="ar" href={arPath} />
  <link rel="alternate" hreflang="en" href={enPath} />
  <link rel="alternate" hreflang="x-default" href={dePath} />

  <!--
    Crimson Pro  — serif display and headings
    Source Sans 3 — interface and body (variable font)
    Noto Naskh Arabic — all Arabic text
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400;1,600&family=Source+Sans+3:wght@300;400;600&family=Noto+Naskh+Arabic:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>

<body>
  <a href="#main-content" class="skip-link">{t(locale, 'skip.label')}</a>

  <!-- ================================================================
       SITE MASTHEAD
  ================================================================ -->
  <div class="site-masthead" role="banner">
    <div class="container">
      <a href={locale === 'de' ? withBase('/') : locale === 'ar' ? withBase('/ar/') : withBase('/en/')}
         class="site-masthead__link"
         aria-label={t(locale, 'site.home-label')}>
        <img
          src={withBase('/assets/logo/lp-logo-web.svg')}
          alt="Language, Legitimacy &amp; Politics logo"
          class="site-masthead__logo"
          width="56"
          height="56"
          loading="eager"
          decoding="async"
        />
        <span class="site-masthead__title" dir="ltr">Language, Legitimacy &amp; Politics</span>
        <span class="site-masthead__subtitle-de" dir="ltr">
          {t(locale, 'site.tagline')}
        </span>
      </a>
    </div>
  </div>

  <!-- ================================================================
       SITE NAV-BAR — sticky navigation
  ================================================================ -->
  <div class="site-nav-bar">
    <div class="container site-nav-bar__inner">

      <nav
        class="site-nav"
        id="main-nav"
        aria-label={t(locale, 'nav.main-label')}
        role="navigation"
      >
        <ul class="site-nav__list" role="list">
          {navItems.map((item) => (
            <li class="site-nav__item">
              <a
                href={withBase(item.href)}
                class={`site-nav__link${isActive(item.href) ? ' is-active' : ''}`}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Language switcher -->
      <nav
        class="lang-switcher"
        aria-label={t(locale, 'lang.switcher-label')}
        dir="ltr"
      >
        <a
          href={dePath}
          class={`lang-switcher__link${locale === 'de' ? ' lang-switcher__link--active' : ''}`}
          lang="de"
          hreflang="de"
          aria-current={locale === 'de' ? 'true' : undefined}
        >DE</a>
        <span class="lang-switcher__sep" aria-hidden="true">|</span>
        <a
          href={arPath}
          class={`lang-switcher__link${locale === 'ar' ? ' lang-switcher__link--active' : ''}`}
          lang="ar"
          hreflang="ar"
          aria-current={locale === 'ar' ? 'true' : undefined}
        >AR</a>
        <span class="lang-switcher__sep" aria-hidden="true">|</span>
        <a
          href={enPath}
          class={`lang-switcher__link${locale === 'en' ? ' lang-switcher__link--active' : ''}`}
          lang="en"
          hreflang="en"
          aria-current={locale === 'en' ? 'true' : undefined}
        >EN</a>

      </nav>

      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-controls="main-nav"
        aria-expanded="false"
        aria-label={t(locale, 'nav.toggle-open')}
      >
        <span class="nav-toggle__icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        {t(locale, 'nav.toggle-label')}
      </button>

    </div>
  </div>

  <!-- ================================================================
       MAIN CONTENT
  ================================================================ -->
  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <!-- ================================================================
       SITE FOOTER
  ================================================================ -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="site-footer__inner">

        <div class="site-footer__project">
          <span class="site-footer__name" dir="ltr">Language, Legitimacy &amp; Politics</span>
          <p>{t(locale, 'footer.description')}</p>
        </div>

        <nav class="site-footer__links" aria-label={locale === 'de' ? 'Footer-Navigation' : locale === 'ar' ? 'تنقل التذييل' : 'Footer navigation'}>
          {footerLinks.map(link => (
            <a href={withBase(link.href)} class="site-footer__link">{link.label}</a>
          ))}
        </nav>

      </div>

      <div class="site-footer__bottom">
        <span>{t(locale, 'footer.bottom')}</span>
        <span>{t(locale, 'footer.sources-note')}</span>
      </div>
    </div>
  </footer>

  <!-- ================================================================
       JAVASCRIPT — Mobile Navigation Toggle
  ================================================================ -->
  <script is:inline define:vars={{ openLabel: t(locale, 'nav.toggle-open'), closeLabel: t(locale, 'nav.toggle-close') }}>
    const toggle = document.getElementById('nav-toggle');
    const nav    = document.getElementById('main-nav');

    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        toggle.setAttribute('aria-label', isOpen ? openLabel : closeLabel);
        nav.classList.toggle('nav--open');
      });

      nav.querySelectorAll('.site-nav__link').forEach((link) => {
        link.addEventListener('click', () => {
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', openLabel);
          nav.classList.remove('nav--open');
        });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && nav.classList.contains('nav--open')) {
          toggle.setAttribute('aria-expanded', 'false');
          nav.classList.remove('nav--open');
          toggle.focus();
        }
      });
    }
  </script>

</body>
</html>

<style>
  /* Language switcher */
  .site-nav-bar__inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* In RTL pages, margin-left: auto pushes switcher to the wrong side.
     The dir="ltr" on the switcher fixes internal order, but we override
     margin for RTL context via a global RTL rule. */

  .lang-switcher__link {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--clr-text-muted);
    text-decoration: none;
    padding: 2px 5px;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .lang-switcher__link:hover {
    color: var(--clr-red);
  }

  .lang-switcher__link:focus-visible {
    outline: 2px solid var(--clr-red);
    outline-offset: 2px;
    color: var(--clr-red);
  }

  .lang-switcher__link--active {
    color: var(--clr-red);
    background-color: var(--clr-olive-pale);
    font-weight: 700;
  }

  .lang-switcher__sep {
    color: var(--clr-border);
    font-size: 0.65rem;
    flex-shrink: 0;
  }

  /* Ensure nav takes remaining space */
  .site-nav {
    flex: 1;
    min-width: 0;
  }

  /* Push toggle to end on mobile */
  .nav-toggle {
    flex-shrink: 0;
  }
</style>
