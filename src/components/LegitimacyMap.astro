---
import 'leaflet/dist/leaflet.css';
import '../styles/map.css';
import mapEventsRaw from '../data/map-events.json';
import { t, type Locale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;

interface MapEvent {
  id: string;
  title_de: string;
  title_en: string;
  title_ar: string;
  date: string;
  date_display: string;
  event_type: string;
  phase: string;
  location_name: string;
  coordinates: [number, number] | null;
  location_certainty: string;
  verification_status: string;
  legitimacy_relevance: string;
  short_description_de: string;
  source_status: string;
  source_links: string[];
  related_corpus_ids: string[];
  show_on_map: boolean;
  connections: Array<{
    target_id: string;
    connection_type: string;
    label_de: string;
    certainty: string;
  }>;
}

const mapEvents = mapEventsRaw as MapEvent[];

// Partition
const geolocated = mapEvents.filter(e => e.show_on_map && e.coordinates !== null);
const nonGeolocated = mapEvents.filter(e => !e.show_on_map || e.coordinates === null);

// Filter options
const phases = [...new Set(mapEvents.map(e => e.phase))].sort();
const eventTypes = [...new Set(mapEvents.map(e => e.event_type))].sort();

// Locale-aware label dictionaries
const eventTypeLabels: Record<string, string> = {
  revolution_context:    t(locale, 'map.event-type.revolution-context'),
  factional_emergence:   t(locale, 'map.event-type.factional-emergence'),
  corpus_item:           t(locale, 'map.event-type.corpus-item'),
  governance_event:      t(locale, 'map.event-type.governance-event'),
  institutional_event:   t(locale, 'map.event-type.institutional-event'),
};

// Phase labels are numeric/neutral — same across locales
const phaseLabels: Record<string, string> = {
  phase_1: 'Phase 1: 2011–2016',
  phase_2: 'Phase 2: 2017–2024',
  phase_3: 'Phase 3: 2025–2026',
};

const legitLabels: Record<string, string> = {
  delegitimation_of_regime:             t(locale, 'map.legit.delegitimation-regime'),
  religious_militant_legitimacy:         t(locale, 'map.legit.religious-militant'),
  administrative_governance_legitimacy:  t(locale, 'map.legit.administrative-governance'),
  institutional_state_legitimacy:        t(locale, 'map.legit.institutional-state'),
  contextual_background:                 t(locale, 'map.legit.contextual-background'),
};

const verificationLabels: Record<string, string> = {
  verified:           t(locale, 'map.verification.verified'),
  partially_verified: t(locale, 'map.verification.partially-verified'),
  needs_review:       t(locale, 'map.verification.needs-review'),
};

const certaintySuffix: Record<string, string> = {
  exact:          t(locale, 'map.certainty.exact'),
  city_level:     t(locale, 'map.certainty.city-level'),
  province_level: t(locale, 'map.certainty.province-level'),
  country_level:  t(locale, 'map.certainty.country-level'),
  unknown:        t(locale, 'map.certainty.unknown'),
};

// Stats
const totalEvents = mapEvents.length;
const geolocatedCount = geolocated.length;
const nonGeoCount = nonGeolocated.length;
const needsReviewCount = mapEvents.filter(e => e.verification_status === 'needs_review').length;

// Locale-aware month names for static date formatting
const MONTHS: Record<Locale, string[]> = {
  de: ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'],
  en: ['January','February','March','April','May','June','July','August','September','October','November','December'],
  ar: ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'],
};
const months = MONTHS[locale];
const dateUnknown = t(locale, 'map.date-unknown');

function displayDate(dateStr: string): string {
  if (!dateStr) return dateUnknown;
  if (/^\d{4}$/.test(dateStr)) return dateStr;
  if (/^\d{4}-\d{2}$/.test(dateStr)) {
    const [y, m] = dateStr.split('-');
    return `${months[parseInt(m, 10) - 1] ?? m} ${y}`;
  }
  const d = new Date(dateStr + 'T12:00:00Z');
  if (isNaN(d.getTime())) return dateStr;
  if (locale === 'de') return `${d.getUTCDate()}. ${months[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
  return `${d.getUTCDate()} ${months[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
}

// Locale-aware event title
function eventTitle(event: MapEvent): string {
  if (locale === 'ar') return event.title_ar || event.title_de;
  if (locale === 'en') return event.title_en || event.title_de;
  return event.title_de;
}

// Chronological sort
const chronological = [...mapEvents].sort((a, b) => {
  const dateA = new Date(a.date + '-01').getTime();
  const dateB = new Date(b.date + '-01').getTime();
  return isNaN(dateA) ? 1 : isNaN(dateB) ? -1 : dateA - dateB;
});
---

<!-- ================================================================
     STATS DASHBOARD
================================================================ -->
<div class="cmap-stats" role="region" aria-label={t(locale, 'map.stat.aria')}>
  <div class="cmap-stat">
    <span class="cmap-stat__num">{totalEvents}</span>
    <span class="cmap-stat__label">{t(locale, 'map.stats.total')}</span>
  </div>
  <div class="cmap-stat cmap-stat--geo">
    <span class="cmap-stat__num">{geolocatedCount}</span>
    <span class="cmap-stat__label">{t(locale, 'map.stats.geolocated')}</span>
  </div>
  <div class="cmap-stat">
    <span class="cmap-stat__num">{nonGeoCount}</span>
    <span class="cmap-stat__label">{t(locale, 'map.stats.non-geolocated')}</span>
  </div>
  <div class="cmap-stat cmap-stat--warn">
    <span class="cmap-stat__num">{needsReviewCount}</span>
    <span class="cmap-stat__label">{t(locale, 'map.stats.needs-review')}</span>
  </div>
</div>

<!-- ================================================================
     FILTERS
================================================================ -->
<div class="cmap-filters" dir="ltr" aria-label={t(locale, 'map.aria.filters')}>
  <div class="cmap-filter-group">
    <label class="cmap-filter-label" for="cmap-filter-phase">Phase</label>
    <select class="cmap-filter-select" id="cmap-filter-phase" name="phase">
      <option value="all">{t(locale, 'map.filter.all-phases')}</option>
      {phases.map(p => (
        <option value={p}>{phaseLabels[p] ?? p}</option>
      ))}
    </select>
  </div>
  <div class="cmap-filter-group">
    <label class="cmap-filter-label" for="cmap-filter-type">{t(locale, 'map.filter.type-label')}</label>
    <select class="cmap-filter-select" id="cmap-filter-type" name="type">
      <option value="all">{t(locale, 'map.filter.all-types')}</option>
      {eventTypes.map(et => (
        <option value={et}>{eventTypeLabels[et] ?? et}</option>
      ))}
    </select>
  </div>
  <div class="cmap-filter-group">
    <label class="cmap-filter-label" for="cmap-filter-verification">{t(locale, 'map.legend.verification-group')}</label>
    <select class="cmap-filter-select" id="cmap-filter-verification" name="verification">
      <option value="all">{t(locale, 'map.filter.all-status')}</option>
      <option value="verified">{t(locale, 'map.verification.verified')}</option>
      <option value="partially_verified">{t(locale, 'map.verification.partially-verified')}</option>
      <option value="needs_review">{t(locale, 'map.verification.needs-review')}</option>
    </select>
  </div>
  <div class="cmap-filter-group">
    <label class="cmap-filter-label" for="cmap-filter-legitimacy">{t(locale, 'map.filter.legitimacy-label')}</label>
    <select class="cmap-filter-select" id="cmap-filter-legitimacy" name="legitimacy">
      <option value="all">{t(locale, 'map.filter.all-legitimacy')}</option>
      <option value="delegitimation_of_regime">{t(locale, 'map.legit.delegitimation-regime')}</option>
      <option value="religious_militant_legitimacy">{t(locale, 'map.legit.religious-militant')}</option>
      <option value="administrative_governance_legitimacy">{t(locale, 'map.legit.administrative-governance')}</option>
      <option value="institutional_state_legitimacy">{t(locale, 'map.legit.institutional-state')}</option>
    </select>
  </div>
  <span class="cmap-count" id="cmap-count" aria-live="polite"></span>
</div>

<!-- ================================================================
     MAIN MAP
================================================================ -->
<div
  id="legitimacy-map"
  dir="ltr"
  role="region"
  aria-label={t(locale, 'map.aria.map')}
></div>

<!-- ================================================================
     LEGEND
================================================================ -->
<div class="cmap-legend" role="region" aria-label={t(locale, 'map.legend.aria')}>
  <span class="cmap-legend__title">{t(locale, 'map.legend.title')}</span>

  <div class="cmap-legend__group">
    <span class="cmap-legend__group-label">{t(locale, 'map.legend.event-types')}</span>
    <div class="cmap-legend__items">
      <div class="cmap-legend__item">
        <span class="cmap-legend__pin cmap-legend__pin--revolution" aria-hidden="true"></span>
        {t(locale, 'map.legend.revolution-context')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__pin cmap-legend__pin--factional" aria-hidden="true"></span>
        {t(locale, 'map.legend.factional-emergence')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__pin cmap-legend__pin--corpus" aria-hidden="true"></span>
        {t(locale, 'map.legend.corpus-item')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__pin cmap-legend__pin--governance" aria-hidden="true"></span>
        {t(locale, 'map.legend.governance-event')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__pin cmap-legend__pin--institutional" aria-hidden="true"></span>
        {t(locale, 'map.legend.institutional-event')}
      </div>
    </div>
  </div>

  <div class="cmap-legend__group">
    <span class="cmap-legend__group-label">{t(locale, 'map.legend.verification-group')}</span>
    <div class="cmap-legend__items">
      <div class="cmap-legend__item">
        <span class="cmap-legend__verify cmap-legend__verify--verified" aria-hidden="true"></span>
        {t(locale, 'map.legend.verified')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__verify cmap-legend__verify--partial" aria-hidden="true"></span>
        {t(locale, 'map.legend.partially-verified')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__verify cmap-legend__verify--review" aria-hidden="true"></span>
        {t(locale, 'map.verification.needs-review')}
      </div>
    </div>
  </div>

  <div class="cmap-legend__group">
    <span class="cmap-legend__group-label">{t(locale, 'map.legend.connections')}</span>
    <div class="cmap-legend__items">
      <div class="cmap-legend__item">
        <span class="cmap-legend__line cmap-legend__line--gold" aria-hidden="true"></span>
        {t(locale, 'map.legend.shift-context')}
      </div>
      <div class="cmap-legend__item">
        <span class="cmap-legend__line cmap-legend__line--brown" aria-hidden="true"></span>
        {t(locale, 'map.legend.shift-corpus')}
      </div>
    </div>
  </div>

</div>


<!-- ================================================================
     NON-GEOLOCATED EVENTS PANEL
================================================================ -->
<section class="cmap-ngeo-section" id="cmap-ngeo" aria-labelledby="cmap-ngeo-title">
  <h2 class="cmap-ngeo-title" id="cmap-ngeo-title">
    {t(locale, 'map.ngeo.section-title')}
  </h2>
  <p class="cmap-ngeo-desc">
    {t(locale, 'map.ngeo.section-desc')}
  </p>

  <div class="cmap-ngeo-grid">
    {nonGeolocated.map(event => (
      <article class="cmap-ngeo-card" data-event-id={event.id}>
        <div class="cmap-ngeo-card__header">
          <span class={`cmap-event-type-badge cmap-event-type-badge--${event.event_type.replace('_','-')}`}>
            {eventTypeLabels[event.event_type] ?? event.event_type}
          </span>
          <span class={`cmap-verify-badge cmap-verify-badge--${event.verification_status}`}>
            {verificationLabels[event.verification_status] ?? event.verification_status}
          </span>
        </div>
        <h3 class="cmap-ngeo-card__title">{eventTitle(event)}</h3>
        <div class="cmap-ngeo-card__meta">
          <div class="cmap-ngeo-card__row">
            <dt>{t(locale, 'map.ngeo.date')}</dt>
            <dd>{displayDate(event.date)}</dd>
          </div>
          <div class="cmap-ngeo-card__row">
            <dt>{t(locale, 'map.ngeo.location-label')}</dt>
            <dd>
              <span class="cmap-uncertainty-badge">
                {event.location_name}
              </span>
            </dd>
          </div>
          <div class="cmap-ngeo-card__row">
            <dt>{t(locale, 'map.ngeo.certainty-label')}</dt>
            <dd>{certaintySuffix[event.location_certainty] ?? event.location_certainty}</dd>
          </div>
          <div class="cmap-ngeo-card__row">
            <dt>{t(locale, 'map.ngeo.legitimacy-label')}</dt>
            <dd>{legitLabels[event.legitimacy_relevance] ?? event.legitimacy_relevance}</dd>
          </div>
          {event.related_corpus_ids.length > 0 && (
            <div class="cmap-ngeo-card__row">
              <dt>{t(locale, 'map.ngeo.corpus-ids-label')}</dt>
              <dd class="cmap-ngeo-card__corpus-ids">
                {event.related_corpus_ids.map(id => (
                  <code class="cmap-corpus-id">{id}</code>
                ))}
              </dd>
            </div>
          )}
        </div>
        <p class="cmap-ngeo-card__desc">{event.short_description_de}</p>
      </article>
    ))}
  </div>
</section>


<!-- ================================================================
     CHRONOLOGICAL EVENT LIST
================================================================ -->
<section class="cmap-chrono-section" id="cmap-chrono" aria-labelledby="cmap-chrono-title">
  <h2 class="cmap-chrono-title" id="cmap-chrono-title">
    {t(locale, 'map.chrono.title')}
  </h2>
  <p class="cmap-chrono-desc">
    {t(locale, 'map.chrono.desc')}
  </p>

  <div class="cmap-chrono-list" role="list">
    {chronological.map(event => (
      <div class="cmap-chrono-item" role="listitem" data-event-id={event.id}>
        <div class="cmap-chrono-item__spine" aria-hidden="true">
          <span class={`cmap-chrono-dot cmap-chrono-dot--${event.event_type.replace('_','-')}`}></span>
          <span class="cmap-chrono-line"></span>
        </div>
        <div class="cmap-chrono-item__body">
          <div class="cmap-chrono-item__top">
            <time class="cmap-chrono-date" dir="ltr" datetime={event.date}>{displayDate(event.date)}</time>
            <span class={`cmap-event-type-badge cmap-event-type-badge--${event.event_type.replace('_','-')}`}>
              {eventTypeLabels[event.event_type] ?? event.event_type}
            </span>
            {event.show_on_map && event.coordinates && (
              <span class="cmap-geo-badge">{t(locale, 'map.badge.geolocated')}</span>
            )}
            {(!event.show_on_map || !event.coordinates) && (
              <span class="cmap-ngeo-badge">{t(locale, 'map.badge.non-geolocated')}</span>
            )}
            <span class={`cmap-verify-dot cmap-verify-dot--${event.verification_status}`} title={verificationLabels[event.verification_status] ?? ''} aria-label={verificationLabels[event.verification_status]}></span>
          </div>
          <p class="cmap-chrono-title">{eventTitle(event)}</p>
          <p class="cmap-chrono-location">{event.location_name}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import '../scripts/map.js';
</script>
